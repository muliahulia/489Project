<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Manage Course</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>
  <style>
    .main {
      padding: 2rem;
    }

    .form-column {
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .breadcrumb a {
      color: var(--text-muted);
      transition: color 0.15s;
    }

    .breadcrumb a:hover {
      color: var(--navy);
    }

    .breadcrumb span {
      color: #c5cfd9;
    }

    .page-title {
      color: var(--text-dark);
      margin-bottom: 0.45rem;
    }

    .page-subtitle {
      font-size: 0.93rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .form-feedback {
      border-radius: 12px;
      padding: 0.9rem 1rem;
      margin-bottom: 1rem;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .form-feedback.error {
      border: 1px solid rgba(176, 58, 46, 0.24);
      background: rgba(176, 58, 46, 0.06);
      color: #8f2f25;
    }

    .form-feedback.success {
      border: 1px solid #b8e5c8;
      background: #f2fbf5;
      color: #22663a;
    }

    .form-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 1px 6px rgba(13,27,42,0.07);
    }

    .section-divider {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: #9aaabb;
      margin: 0 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }

    .field {
      margin-bottom: 1.2rem;
    }

    .field label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-dark);
      margin-bottom: 0.45rem;
    }

    .field input[type="text"],
    .field input[type="number"],
    .field textarea {
      width: 100%;
      padding: 0.7rem 0.95rem;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.92rem;
      color: var(--text-dark);
      background: #fff;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .field input[type="text"]:focus,
    .field input[type="number"]:focus,
    .field textarea:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
    }

    .field textarea {
      resize: vertical;
      min-height: 140px;
    }

    .field .hint {
      display: block;
      margin-top: 0.45rem;
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .field-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .actions {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }

    .btn-primary,
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      padding: 0.75rem 1.15rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

    .btn-primary {
      border: none;
      background: var(--navy);
      color: var(--gold);
    }

    .btn-primary:hover {
      background: var(--navy-mid);
    }

    .btn-secondary {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--navy);
    }

    .btn-secondary:hover {
      border-color: var(--navy);
      background: var(--cream);
    }

    @media (max-width: 640px) {
      .field-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>

  <%- include('header', { user }) %>

  <div class="layout">
    <%- include('sidebar', { activePage: 'courses' }) %>

    <main class="main">
      <div class="form-column">
        <nav class="breadcrumb">
          <a href="/courses">Courses</a>
          <span>›</span>
          <a href="/courses/<%= courseId %>"><%= courseName %></a>
          <span>›</span>
          <span>Manage</span>
        </nav>

        <h1 class="page-title">Manage Course</h1>
        <p class="page-subtitle">Update the details for <strong><%= courseName %></strong> at <strong><%= schoolName %></strong>.</p>

        <% if (formError) { %>
          <div class="form-feedback error"><%= formError %></div>
        <% } %>

        <% if (formSuccess) { %>
          <div class="form-feedback success"><%= formSuccess %></div>
        <% } %>

        <div class="form-card">
          <form method="post" action="/courses/manage/<%= courseId %>">
            <div class="section-divider">Course Details</div>

            <div class="field-grid">
              <div class="field">
                <label for="course_prefix">Course prefix</label>
                <input
                  id="course_prefix"
                  name="course_prefix"
                  type="text"
                  maxlength="16"
                  value="<%= coursePrefix %>"
                  placeholder="Example: CPT_S"
                />
                <span class="hint">Optional short code such as `CPT_S` or `MATH`.</span>
              </div>

              <div class="field">
                <label for="course_number">Course number</label>
                <input
                  id="course_number"
                  name="course_number"
                  type="number"
                  min="0"
                  max="32767"
                  step="1"
                  value="<%= courseNumber %>"
                  placeholder="Example: 489"
                />
                <span class="hint">Optional numeric code stored with the course record.</span>
              </div>
            </div>

            <div class="field">
              <label for="instructor_name">Instructor</label>
              <input
                id="instructor_name"
                name="instructor_name"
                type="text"
                maxlength="120"
                value="<%= instructorName %>"
                placeholder="Example: Dr. Maya Chen"
                required
              />
              <span class="hint">This is the name shown on the course card and detail page.</span>
            </div>

            <div class="field">
              <label for="name">Course name</label>
              <input
                id="name"
                name="name"
                type="text"
                maxlength="120"
                value="<%= courseName %>"
                placeholder="Example: Introduction to Data Structures"
                required
              />
              <span class="hint">Keep it short and recognizable. Maximum 120 characters.</span>
            </div>

            <div class="field">
              <label for="description">Course description</label>
              <textarea
                id="description"
                name="description"
                maxlength="1000"
                placeholder="Add a brief description so students know what this course covers."><%= courseDescription %></textarea>
              <span class="hint">Optional, but helpful. Maximum 1000 characters.</span>
            </div>

            <div class="actions">
              <button class="btn-primary" type="submit">Save changes</button>
              <a class="btn-secondary" href="/courses/<%= courseId %>">Back to course</a>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>

  <%- include('footer', { footerLayout: 'sidebarLeft' }) %>

</body>
</html>
