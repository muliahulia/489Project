<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <!-- Tailwind required for footer -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: '#0d1b2a',
            'navy-mid': '#1a2e45',
            'navy-light': '#243b55',
            gold: '#c9a84c',
            'gold-light': '#e8c97a',
            cream: '#f5f0e8',
            'cream-dark': '#ede5d6',
          },
          fontFamily: {
            'serif': ['Playfair Display', 'serif'],
            'sans': ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    /* ── Topbar ── */

    /* ── Layout ── */
    .layout {
      display: flex;
      padding-top: var(--topbar-h);
      min-height: 100vh;
    }


    /* ── Main ── */
    .main {
      flex: 1;
      margin-left: var(--sidebar-w);
      padding: 2.5rem 2rem;
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .dash-column {
      width: 100%;
      max-width: 720px;
    }

    /* ── Greeting ── */
    .greeting-name {
      font-family: 'Playfair Display', serif;
      font-size: 2.1rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.3rem;
    }

    .greeting-quote {
      font-size: 0.9rem;
      color: var(--text-muted);
      font-style: italic;
      margin-bottom: 2rem;
    }

    /* ── Section label ── */
    .dash-section-label {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #9aaabb;
      margin-bottom: 0.85rem;
    }

    /* ── Scroll card (shared by courses & communities) ── */
    .scroll-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.1rem 1.25rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 2rem;
      overflow-x: auto;
    }

    .scroll-row {
      display: flex;
      gap: 1.1rem;
      align-items: flex-start;
      /* allow horizontal scroll on small viewports */
      min-width: max-content;
    }

    /* ── Circle item ── */
    .circle-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.45rem;
      text-decoration: none;
      cursor: pointer;
    }

    .circle-bubble {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.72rem;
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      line-height: 1.25;
      padding: 0.4rem;
      border: 2px solid var(--border);
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .circle-item:hover .circle-bubble {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(201,168,76,0.2);
    }

    .circle-label {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--text-muted);
      text-align: center;
      max-width: 72px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Vary community bubble colors for visual distinction */
    .circle-bubble.community-1 { background: var(--navy-mid); }
    .circle-bubble.community-2 { background: #2c4a6e; }
    .circle-bubble.community-3 { background: var(--navy-light); }
    .circle-bubble.community-4 { background: #1e3a52; }
    .circle-bubble.community-5 { background: var(--navy); }
  </style>
</head>
<body>

  <%- include('header', { initials: 'JS' }) %>

  <div class="layout">

    <!-- Left Sidebar -->
    <%- include('sidebar', { activePage: 'dashboard' }) %>

    <!-- Main Content -->
    <main class="main">
      <div class="dash-column">

        <!-- Greeting -->
        <h1 class="greeting-name">Hello, Jane!</h1>
        <p class="greeting-quote">"The secret of getting ahead is getting started." — Mark Twain</p>

        <!-- Your Courses -->
        <div class="dash-section-label">Your courses</div>
        <div class="scroll-card">
          <div class="scroll-row">
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">CPT_S<br>101</div>
              <span class="circle-label" title="Intro to Programming">Intro to Programming</span>
            </a>
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">CPT_S<br>223</div>
              <span class="circle-label" title="Data Structures">Data Structures</span>
            </a>
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">CPT_S<br>350</div>
              <span class="circle-label" title="Systems Programming">Systems Programming</span>
            </a>
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">CPT_S<br>451</div>
              <span class="circle-label" title="Database Systems">Database Systems</span>
            </a>
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">CPT_S<br>489</div>
              <span class="circle-label" title="Web Development">Web Development</span>
            </a>
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">MATH<br>315</div>
              <span class="circle-label" title="Discrete Mathematics">Discrete Mathematics</span>
            </a>
            <a href="course.html" class="circle-item">
              <div class="circle-bubble">CPT_S<br>427</div>
              <span class="circle-label" title="Machine Learning">Machine Learning</span>
            </a>
          </div>
        </div>

        <!-- Your Communities -->
        <div class="dash-section-label">Your communities</div>
        <div class="scroll-card">
          <div class="scroll-row">
            <a href="community.html" class="circle-item">
              <div class="circle-bubble community-1">CS<br>Club</div>
              <span class="circle-label" title="Computer Science Club">Computer Science Club</span>
            </a>
            <a href="community.html" class="circle-item">
              <div class="circle-bubble community-2">Algo<br>SG</div>
              <span class="circle-label" title="Algorithms Study Group">Algorithms Study Group</span>
            </a>
            <a href="community.html" class="circle-item">
              <div class="circle-bubble community-3">Hack<br>WSU</div>
              <span class="circle-label" title="HackWSU">HackWSU</span>
            </a>
            <a href="community.html" class="circle-item">
              <div class="circle-bubble community-4">AI/ML<br>Club</div>
              <span class="circle-label" title="AI &amp; ML Interest Group">AI &amp; ML Interest Group</span>
            </a>
            <a href="community.html" class="circle-item">
              <div class="circle-bubble community-5">Open<br>Src</div>
              <span class="circle-label" title="Open Source Initiative">Open Source Initiative</span>
            </a>
            <a href="community.html" class="circle-item">
              <div class="circle-bubble community-1">Women<br>CS</div>
              <span class="circle-label" title="Women in Computer Science">Women in Computer Science</span>
            </a>
          </div>
        </div>

      </div><!-- /.dash-column -->
    </main>

  </div><!-- /.layout -->

  <%- include('footer', { footerLayout: 'sidebarLeft' }) %>

</body>
</html>
