<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Settings</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <style>
    /* Page-specific styles */


    .avatar-row { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem; }
    .avatar-circle { width: 72px; height: 72px; border-radius: 50%; background: var(--gold); color: var(--navy); font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .avatar-hint { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.3rem; }

    .save-alert { display: none; align-items: center; gap: 0.65rem; padding: 0.85rem 1rem; border-radius: 10px; font-size: 0.87rem; background: rgba(30,126,92,0.08); color: var(--success); border: 1px solid rgba(30,126,92,0.2); margin-bottom: 1.25rem; }

    .linked-item { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 0; border-bottom: 1px solid var(--border); }
    .linked-item:last-child { border-bottom: none; }
    .linked-left { display: flex; align-items: center; gap: 0.75rem; }
    .linked-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; background: var(--cream-dark); }
    .linked-info strong { display: block; font-size: 0.9rem; font-weight: 600; }
    .linked-info span { font-size: 0.78rem; color: var(--text-muted); }

    .danger-card { border: 1px solid rgba(192,57,43,0.25); border-radius: 14px; padding: 1.75rem; background: rgba(192,57,43,0.03); }
    .danger-card .card-title { color: var(--error); border-bottom-color: rgba(192,57,43,0.15); }
    .danger-item { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid rgba(192,57,43,0.1); }
    .danger-item:last-child { border-bottom: none; }
    .danger-item strong { display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 2px; }
    .danger-item span { font-size: 0.8rem; color: var(--text-muted); }

  </style>
</head>
<body>

  <%- include('header', { initials: 'LG' }) %>

  <div class="layout">

    <%- include('sidebar', { activePage: 'settings' }) %>

    <!-- Main content area -->
    <main class="main main-pad main-contained">

      <div class="page-header">
        <h1 class="page-title">Settings</h1>
        <p class="page-subtitle">Manage your account preferences and privacy.</p>
      </div>

      <!-- Save confirmation -->
      <div class="save-alert" id="save-alert">✅ Your changes have been saved.</div>

      <!-- Tabs -->
      <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('profile', this)">Profile</button>
        <button class="tab-btn" onclick="switchTab('password', this)">Password</button>
        <button class="tab-btn" onclick="switchTab('notifications', this)">Notifications</button>
        <button class="tab-btn" onclick="switchTab('linked', this)">Linked Accounts</button>
        <button class="tab-btn" onclick="switchTab('danger', this)">Danger Zone</button>
      </div>

      <!-- PROFILE -->
      <div class="tab-panel active" id="tab-profile">

        <div class="card">
          <div class="card-title">Profile Information</div>
          <div class="avatar-row">
            <div class="avatar-circle">JS</div>
            <div>
              <button class="btn btn-secondary btn-sm">Upload Photo</button>
              <p class="avatar-hint">JPG or PNG, max 2MB</p>
            </div>
          </div>
          <div class="form-row">
            <div class="field"><label>First Name</label><input type="text" value="Jane"/></div>
            <div class="field"><label>Last Name</label><input type="text" value="Smith"/></div>
          </div>
          <div class="field"><label>Username</label><input type="text" value="@janesmith"/></div>
          <div class="field">
            <label>Bio</label>
            <textarea placeholder="Tell others about yourself..."></textarea>
          </div>
          <div class="form-actions">
            <button class="btn btn-secondary btn-sm">Discard</button>
            <button class="btn btn-primary" onclick="showSave()">Save Changes</button>
          </div>
        </div>

        <div class="card">
          <div class="card-title">University Affiliation</div>
          <div class="field">
            <label>University Email</label>
            <input type="email" value="jane.smith@university.edu" readonly style="background:var(--cream); cursor:not-allowed;"/>
          </div>
          <div style="display:flex; align-items:center; gap:0.6rem; font-size:0.85rem; color:var(--text-muted);">
            <span class="badge badge-success">✓ Verified</span> Affiliated with State University
          </div>
        </div>

      </div>

      <!-- PASSWORD -->
      <div class="tab-panel" id="tab-password">
        <div class="card">
          <div class="card-title">Change Password</div>
          <div class="field"><label>Current Password</label><input type="password" placeholder="••••••••"/></div>
          <div class="field"><label>New Password</label><input type="password" placeholder="••••••••"/></div>
          <div class="field"><label>Confirm New Password</label><input type="password" placeholder="••••••••"/></div>
          <div class="form-actions">
            <button class="btn btn-primary" onclick="showSave()">Update Password</button>
          </div>
        </div>
      </div>

      <!-- NOTIFICATIONS -->
      <div class="tab-panel" id="tab-notifications">
        <div class="card">
          <div class="card-title">Notification Preferences</div>
          <div class="toggle-row">
            <div class="toggle-info"><strong>New Followers</strong><span>When someone follows you</span></div>
            <label class="toggle"><input type="checkbox" checked/><div class="toggle-track"></div></label>
          </div>
          <div class="toggle-row">
            <div class="toggle-info"><strong>Post Reactions</strong><span>Likes, smiles, and hearts on your posts</span></div>
            <label class="toggle"><input type="checkbox" checked/><div class="toggle-track"></div></label>
          </div>
          <div class="toggle-row">
            <div class="toggle-info"><strong>Comments & Replies</strong><span>When someone replies to your post</span></div>
            <label class="toggle"><input type="checkbox" checked/><div class="toggle-track"></div></label>
          </div>
          <div class="toggle-row">
            <div class="toggle-info"><strong>Community Updates</strong><span>Activity in communities you've joined</span></div>
            <label class="toggle"><input type="checkbox"/><div class="toggle-track"></div></label>
          </div>
          <div class="toggle-row">
            <div class="toggle-info"><strong>Official Announcements</strong><span>Posts from your school officials</span></div>
            <label class="toggle"><input type="checkbox" checked/><div class="toggle-track"></div></label>
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" onclick="showSave()">Save Preferences</button>
          </div>
        </div>
      </div>

      <!-- LINKED ACCOUNTS -->
      <div class="tab-panel" id="tab-linked">
        <div class="card">
          <div class="card-title">Linked Accounts</div>
          <div class="linked-item">
            <div class="linked-left">
              <div class="linked-icon">💬</div>
              <div class="linked-info"><strong>Discord</strong><span>janesmith#4291 — Connected</span></div>
            </div>
            <button class="btn btn-danger btn-sm">Unlink</button>
          </div>
          <div class="linked-item">
            <div class="linked-left">
              <div class="linked-icon">🐙</div>
              <div class="linked-info"><strong>GitHub</strong><span>Not connected</span></div>
            </div>
            <button class="btn btn-secondary btn-sm">Connect</button>
          </div>
          <div class="linked-item">
            <div class="linked-left">
              <div class="linked-icon">💼</div>
              <div class="linked-info"><strong>LinkedIn</strong><span>Not connected</span></div>
            </div>
            <button class="btn btn-secondary btn-sm">Connect</button>
          </div>
        </div>
      </div>

      <!-- DANGER ZONE -->
      <div class="tab-panel" id="tab-danger">
        <div class="danger-card">
          <div class="card-title">⚠️ Danger Zone</div>
          <div class="danger-item">
            <div><strong>Deactivate Account</strong><span>Temporarily hide your profile and posts</span></div>
            <button class="btn btn-secondary btn-sm">Deactivate</button>
          </div>
          <div class="danger-item">
            <div><strong>Delete Account</strong><span>Permanently delete your account and all data</span></div>
            <button class="btn btn-danger btn-sm">Delete Account</button>
          </div>
        </div>
      </div>

    </main>
  </div>

  <script>
    function switchTab(name, btn) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      btn.classList.add('active');
    }
    function showSave() {
      const a = document.getElementById('save-alert');
      a.style.display = 'flex';
      setTimeout(() => a.style.display = 'none', 3000);
    }
  </script>

</body>
</html>