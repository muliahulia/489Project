<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Settings</title>

  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>

  <style>
    .main { padding: 2rem; max-width: 900px; margin: auto; }

    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .field { margin-bottom: 1rem; }

    label {
      font-size: 0.85rem;
      color: var(--text-muted);
      display: block;
      margin-bottom: 5px;
    }

    input, textarea {
      width: 100%;
      padding: 0.6rem;
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    textarea { min-height: 100px; }

    .avatar {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.2rem;
      margin-bottom: 1rem;
    }

    .btn {
      padding: 0.6rem 1rem;
      border-radius: 8px;
      border: none;
      cursor: pointer;
    }

    .btn-primary { background: var(--navy); color: white; }
  </style>
</head>

<body>

<%
  const p = profile || {};
  const initials = (p.first_name?.[0] || user?.email?.[0] || 'U').toUpperCase();
%>

<%- include('header', { initials }) %>

<div class="layout">
  <%- include('sidebar', { activePage: 'settings' }) %>

  <main class="main">

    <h2>Settings</h2>

    <form method="POST" action="/settings/update">

      <div class="card">

        <div class="avatar">
          <%= initials %>
        </div>

        <div class="field">
          <label>First Name</label>
          <input name="first_name" value="<%= p.first_name || '' %>"/>
        </div>

        <div class="field">
          <label>Last Name</label>
          <input name="last_name" value="<%= p.last_name || '' %>"/>
        </div>

        <div class="field">
          <label>Bio</label>
          <textarea name="bio"><%= p.bio || '' %></textarea>
        </div>

        <div class="field">
          <label>Email</label>
          <input value="<%= user?.email || '' %>" readonly />
        </div>

        <button class="btn btn-primary" type="submit">
          Save Changes
        </button>

      </div>

    </form>

  </main>
</div>

</body>
</html>