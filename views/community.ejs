  </div>

  <!-- Footer -->
  <footer class="bg-cream relative z-10 py-8 sm:py-12 border-t-2 border-gold/20" style="margin-left: var(--sidebar-w);">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8 text-center md:text-left">

        <div>
          <h3 class="font-serif text-lg sm:text-xl font-bold text-navy mb-3">About UniConnect</h3>
          <p class="text-navy/70 text-sm leading-relaxed">
            A verified academic platform connecting students, faculty, and administrators across universities.
          </p>
        </div>

        <div>
          <h3 class="font-serif text-lg sm:text-xl font-bold text-navy mb-3">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="#" class="text-navy/70 hover:text-gold transition">Privacy Policy</a></li>
            <li><a href="#" class="text-navy/70 hover:text-gold transition">Terms of Service</a></li>
