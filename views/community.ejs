<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Community</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <!-- Tailwind required for footer -->
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>
  <style>
    /* ── Topbar ── */

    /* ── Main ── */
    .main {
      padding: 2rem;
    }

    .course-column {
      width: 100%;
      max-width: 680px;
      margin: 0 auto;
    }

    /* ── Community Header ── */
    .course-header {
      margin-bottom: 1.5rem;
    }

    .course-header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .course-title {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.25rem;
    }

    .course-instructor {
      font-size: 0.88rem;
      color: var(--text-muted);
      margin-bottom: 0.6rem;
    }

    .course-description {
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.65;
    }

    .membership-btn {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.45rem 0.85rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      background: #fff;
      color: var(--text-dark);
    }

    .membership-btn.join {
      background: var(--navy);
      border-color: var(--navy);
      color: var(--gold);
    }

    .membership-btn.leave {
      background: var(--cream);
    }

    .membership-owner {
      font-size: 0.78rem;
      color: var(--text-muted);
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    /* ── Members Card ── */
    .members-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 2rem;
    }

    .members-label {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9aaabb;
      margin-bottom: 0.75rem;
    }

    .members-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .member-avatar {
      width: 46px; height: 46px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.78rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid #fff;
      flex-shrink: 0;
      letter-spacing: 0.03em;
    }

    .member-avatar:nth-child(2) { background: var(--navy-mid); }
    .member-avatar:nth-child(3) { background: var(--navy-light); }
    .member-avatar:nth-child(4) { background: #2c4a6e; }
    .member-avatar:nth-child(5) { background: #1e3a52; }

    .members-overflow {
      font-size: 0.82rem;
      color: var(--navy);
      font-weight: 600;
      margin-left: 0.4rem;
      white-space: nowrap;
      background: none;
      border: none;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      padding: 0;
      text-decoration: none;
    }
    .members-overflow:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    /* ── Modal ── */
    .modal-backdrop {
      display: none;
      position: fixed; inset: 0;
      background: rgba(13,27,42,0.45);
      z-index: 200;
      align-items: center;
      justify-content: center;
    }
    .modal-backdrop.open { display: flex; }

    .modal {
      background: #fff;
      border-radius: 16px;
      width: 100%;
      max-width: 480px;
      max-height: 80vh;
      display: flex;
      flex-direction: column;
      box-shadow: 0 8px 40px rgba(13,27,42,0.18);
      overflow: hidden;
      margin: 1rem;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .modal-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text-dark);
    }

    .modal-close {
      width: 32px; height: 32px;
      border-radius: 50%;
      border: none;
      background: var(--cream);
      color: var(--text-muted);
      font-size: 1.1rem;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s, color 0.15s;
    }
    .modal-close:hover { background: var(--cream-dark); color: var(--navy); }

    .modal-body {
      overflow-y: auto;
      padding: 0.75rem 1.5rem 1.5rem;
    }

    .modal-student {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.6rem 0;
      border-bottom: 1px solid var(--border);
    }
    .modal-student:last-child { border-bottom: none; }

    .modal-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.75rem;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      letter-spacing: 0.03em;
    }

    .modal-student-name {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-dark);
    }

    /* ── Feed Section ── */
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 1rem;
    }

    .compose-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.1rem;
      margin-bottom: 1rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
    }

    .compose-textarea {
      width: 100%;
      min-height: 88px;
      resize: vertical;
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 0.8rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--text-dark);
      outline: none;
    }

    .compose-textarea:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
    }

    .compose-footer {
      margin-top: 0.65rem;
      display: flex;
      justify-content: flex-end;
    }

    .compose-submit {
      border: none;
      border-radius: 8px;
      padding: 0.5rem 0.85rem;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      background: var(--navy);
      color: var(--gold);
    }

    .compose-locked {
      font-size: 0.84rem;
      color: var(--text-muted);
    }

    .compose-error {
      margin-bottom: 0.7rem;
      padding: 0.6rem 0.75rem;
      border: 1px solid rgba(192,57,43,0.35);
      border-radius: 8px;
      background: rgba(192,57,43,0.08);
      color: #b03a2e;
      font-size: 0.82rem;
      font-weight: 600;
    }

    /* ── Post Cards ── */
    .post-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      position: relative;
      margin-bottom: 1.25rem;
      width: 100%;
    }

    .post-actions {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      display: flex;
      gap: 0.5rem;
    }

    .post-action-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--cream);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      color: var(--text-muted);
      transition: background 0.15s, color 0.15s;
    }
    .post-action-btn:hover { background: var(--cream-dark); color: var(--navy); }

    .post-author {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-right: 8rem;
    }

    .post-avatar-initials {
      width: 56px; height: 56px;
      border-radius: 50%;
      flex-shrink: 0;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.85rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid var(--border);
      letter-spacing: 0.03em;
    }

    .post-author-info { display: flex; flex-direction: column; gap: 0.15rem; }

    .post-author-name { font-weight: 600; font-size: 1rem; color: var(--text-dark); }
    .post-author-name a { color: var(--text-dark); text-decoration: none; }
    .post-author-name a:hover { text-decoration: underline; text-underline-offset: 2px; }

    .post-meta { font-size: 0.8rem; color: var(--text-muted); }
    .post-meta a { color: var(--text-muted); text-decoration: none; }
    .post-meta a:hover { color: var(--navy); text-decoration: underline; text-underline-offset: 2px; }

    .post-community { font-size: 0.8rem; color: var(--navy); font-weight: 500; }
    .post-community a { color: var(--navy); text-decoration: none; }
    .post-community a:hover { text-decoration: underline; text-underline-offset: 2px; }

    .post-body {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.6;
    }
  </style>
</head>
<body>

  <%
    const communityUser = typeof user !== 'undefined' && user ? user : { initials: 'UC' };
    const activeCommunity = typeof community !== 'undefined' ? community : null;
    const communityMembers = Array.isArray(members) ? members : [];
    const previewMembers = Array.isArray(memberPreview) ? memberPreview : [];
    const postList = Array.isArray(posts) ? posts : [];
    const hiddenMemberCount = Number.isInteger(remainingMemberCount) ? remainingMemberCount : 0;
    const noCommunityMessage = typeof notFoundMessage === 'string' ? notFoundMessage : '';
    const communityFormError = typeof formError === 'string' ? formError : '';
  %>

  <%- include('header', { initials: communityUser.initials || 'UC' }) %>

  <div class="layout">

    <!-- Left Sidebar -->
    <%- include('sidebar', { activePage: 'communities' }) %>

    <!-- Main Content -->
    <main class="main">
      <div class="course-column">

        <% if (activeCommunity) { %>
          <div class="course-header">
            <div class="course-header-top">
              <h1 class="course-title"><%= activeCommunity.name %></h1>
              <% if (activeCommunity.isCreator) { %>
                <span class="membership-owner">Owner</span>
              <% } else if (activeCommunity.canLeave) { %>
                <form method="POST" action="/communities/<%= activeCommunity.id %>/leave">
                  <input type="hidden" name="redirectTo" value="/communities/<%= activeCommunity.id %>" />
                  <button type="submit" class="membership-btn leave">Leave Community</button>
                </form>
              <% } else { %>
                <form method="POST" action="/communities/<%= activeCommunity.id %>/join">
                  <input type="hidden" name="redirectTo" value="/communities/<%= activeCommunity.id %>" />
                  <button type="submit" class="membership-btn join">Join Community</button>
                </form>
              <% } %>
            </div>
            <p class="course-instructor"><%= activeCommunity.metaLine %></p>
            <p class="course-description"><%= activeCommunity.description %></p>
          </div>

          <div class="members-card">
            <div class="members-label">Members</div>
            <div class="members-row">
              <% previewMembers.forEach((member) => { %>
                <div class="member-avatar"><%= member.initials %></div>
              <% }) %>

              <% if (communityMembers.length > 0 && hiddenMemberCount > 0) { %>
                <button class="members-overflow" onclick="document.getElementById('membersModal').classList.add('open')">... and <%= hiddenMemberCount %> others.</button>
              <% } else if (communityMembers.length > 0) { %>
                <button class="members-overflow" onclick="document.getElementById('membersModal').classList.add('open')">View all members</button>
              <% } else { %>
                <span class="members-overflow">No members yet.</span>
              <% } %>
            </div>
          </div>

          <h2 class="section-title">Feed</h2>

          <% if (activeCommunity.canPost) { %>
            <div class="compose-card">
              <% if (communityFormError) { %>
                <div class="compose-error"><%= communityFormError %></div>
              <% } %>
              <form method="POST" action="/communities/<%= activeCommunity.id %>/posts">
                <textarea
                  name="content"
                  class="compose-textarea"
                  maxlength="4000"
                  placeholder="Share something with this community..."
                  required
                ></textarea>
                <div class="compose-footer">
                  <button type="submit" class="compose-submit">Post</button>
                </div>
              </form>
            </div>
          <% } else { %>
            <div class="compose-card">
              <p class="compose-locked">Join this community to publish posts in this feed.</p>
            </div>
          <% } %>

          <% if (postList.length === 0) { %>
            <div class="post-card">
              <div class="post-body">
                <p>No posts have been published in this community yet.</p>
              </div>
            </div>
          <% } %>

          <% postList.forEach((post) => { %>
            <%- include('partials/post-card', { post }) %>
          <% }) %>
        <% } else { %>
          <div class="course-header">
            <h1 class="course-title">Community</h1>
            <p class="course-instructor"><%= noCommunityMessage || 'No community is currently available.' %></p>
          </div>
        <% } %>

      </div><!-- /.course-column -->
    </main>

  </div><!-- /.layout -->

  <% if (activeCommunity) { %>
    <div class="modal-backdrop" id="membersModal" onclick="if(event.target===this)this.classList.remove('open')">
      <div class="modal">
        <div class="modal-header">
          <span class="modal-title">Members - <%= activeCommunity.name %></span>
          <button class="modal-close" onclick="document.getElementById('membersModal').classList.remove('open')">&times;</button>
        </div>
        <div class="modal-body">
          <% if (communityMembers.length === 0) { %>
            <div class="modal-student">
              <span class="modal-student-name">No members yet.</span>
            </div>
          <% } %>

          <% communityMembers.forEach((member) => { %>
            <div class="modal-student">
              <div class="modal-avatar"><%= member.initials %></div>
              <span class="modal-student-name"><%= member.name %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>

  <%- include('footer', { footerLayout: 'sidebarLeft' }) %>

  <script>
    const latestCommentTimers = new WeakMap();

    function buildCommentHtml(comment) {
      return `
        <div class="post-comment">
          <div class="post-comment-avatar">${comment.authorInitials || 'UC'}</div>
          <div class="post-comment-body">
            <div class="post-comment-meta">
              <strong>${comment.authorName || 'Unknown User'}</strong>
              <span>${comment.createdAtLabel || ''}</span>
            </div>
            <div class="post-comment-text">${(comment.content || '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')}</div>
          </div>
        </div>
      `;
    }

    function updateCommentBadge(postCard, count) {
      const toggleButton = postCard.querySelector('.js-comment-toggle');
      if (!toggleButton) {
        return;
      }

      let countNode = toggleButton.querySelector('.comment-count');
      if (!countNode) {
        countNode = document.createElement('span');
        countNode.className = 'comment-count';
        toggleButton.appendChild(document.createTextNode(' '));
        toggleButton.appendChild(countNode);
      }

      countNode.textContent = String(count || 0);
      countNode.classList.toggle('is-hidden', !(count > 0));
    }

    function clearLatestCommentHighlight(postCard) {
      const highlightedComment = postCard.querySelector('.post-comment.focused');
      if (highlightedComment) {
        highlightedComment.classList.remove('focused');
      }
    }

    function flashLatestComment(postCard) {
      clearLatestCommentHighlight(postCard);

      const latestComment = postCard.querySelector('.post-comment[data-comment-id]:last-child');
      if (!latestComment) {
        return;
      }

      latestComment.classList.add('focused');

      const existingTimer = latestCommentTimers.get(postCard);
      if (existingTimer) {
        window.clearTimeout(existingTimer);
      }

      const timerId = window.setTimeout(() => {
        latestComment.classList.remove('focused');
        latestCommentTimers.delete(postCard);
      }, 1200);

      latestCommentTimers.set(postCard, timerId);
      latestComment.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function openComments(postCard) {
      const commentsPanel = postCard.querySelector('.post-comments');
      const toggleButton = postCard.querySelector('.js-comment-toggle');
      const preview = postCard.querySelector('.post-comment-preview');
      if (!commentsPanel || !toggleButton || !commentsPanel.hidden) {
        return;
      }

      commentsPanel.hidden = false;
      toggleButton.classList.add('active');
      toggleButton.setAttribute('aria-expanded', 'true');

      if (preview) {
        preview.hidden = true;
      }

      const input = commentsPanel.querySelector('.post-comment-input');
      if (input) {
        input.focus();
      }
    }

    function collapseComments(postCard) {
      const commentsPanel = postCard.querySelector('.post-comments');
      const toggleButton = postCard.querySelector('.js-comment-toggle');
      const preview = postCard.querySelector('.post-comment-preview');

      if (!commentsPanel || !toggleButton) {
        return;
      }

      commentsPanel.hidden = true;
      toggleButton.classList.remove('active');
      toggleButton.setAttribute('aria-expanded', 'false');

      clearLatestCommentHighlight(postCard);

      const timerId = latestCommentTimers.get(postCard);
      if (timerId) {
        window.clearTimeout(timerId);
        latestCommentTimers.delete(postCard);
      }

      if (preview) {
        preview.hidden = false;
      }
    }

    document.addEventListener('click', async (event) => {
      const likeButton = event.target.closest('.js-like-btn');
      if (!likeButton) {
        return;
      }

      event.preventDefault();

      const postId = likeButton.dataset.postId;
      if (!postId) {
        return;
      }

      if (likeButton.dataset.pending === 'true') {
        return;
      }

      const countNode = likeButton.querySelector('.like-count');
      const previousLiked = likeButton.dataset.liked === 'true';
      const previousCount = countNode ? Number.parseInt(countNode.textContent, 10) || 0 : 0;

      const optimisticLiked = !previousLiked;
      const optimisticCount = Math.max(0, previousCount + (optimisticLiked ? 1 : -1));

      likeButton.dataset.pending = 'true';
      likeButton.classList.add('pending');
      likeButton.dataset.liked = optimisticLiked ? 'true' : 'false';
      likeButton.setAttribute('aria-pressed', optimisticLiked ? 'true' : 'false');
      likeButton.classList.toggle('active', optimisticLiked);
      if (countNode) {
        countNode.textContent = String(optimisticCount);
      }

      try {
        const response = await fetch(`/feed/posts/${postId}/like`, {
          method: 'POST',
          headers: {
            Accept: 'application/json',
          },
        });

        const payload = await response.json();
        if (!response.ok) {
          throw new Error(payload.error || 'Unable to update like.');
        }

        likeButton.dataset.liked = payload.liked ? 'true' : 'false';
        likeButton.setAttribute('aria-pressed', payload.liked ? 'true' : 'false');
        likeButton.classList.toggle('active', Boolean(payload.liked));
        if (countNode) {
          countNode.textContent = String(payload.likeCount || 0);
        }
      } catch (_err) {
        likeButton.dataset.liked = previousLiked ? 'true' : 'false';
        likeButton.setAttribute('aria-pressed', previousLiked ? 'true' : 'false');
        likeButton.classList.toggle('active', previousLiked);
        if (countNode) {
          countNode.textContent = String(previousCount);
        }
      } finally {
        likeButton.dataset.pending = 'false';
        likeButton.classList.remove('pending');
      }
    });

    document.addEventListener('click', (event) => {
      const commentTrigger = event.target.closest('.js-comment-toggle, .js-comment-expand');
      if (!commentTrigger) {
        return;
      }

      const postCard = commentTrigger.closest('.post-card');
      if (!postCard) {
        return;
      }

      const isToggleButton = commentTrigger.classList.contains('js-comment-toggle');
      const isExpandButton = commentTrigger.classList.contains('js-comment-expand');
      const commentsPanel = postCard.querySelector('.post-comments');

      if (!commentsPanel) {
        return;
      }

      if (isToggleButton) {
        if (commentsPanel.hidden) {
          openComments(postCard);
        } else {
          collapseComments(postCard);
        }
        return;
      }

      if (isExpandButton) {
        if (commentsPanel.hidden) {
          openComments(postCard);
        }

        flashLatestComment(postCard);
      }
    });

    document.addEventListener('submit', async (event) => {
      const commentForm = event.target.closest('.js-comment-form');
      if (!commentForm) {
        return;
      }

      event.preventDefault();

      const postId = commentForm.dataset.postId;
      const input = commentForm.querySelector('.post-comment-input');
      const submitButton = commentForm.querySelector('.post-comment-submit');
      const commentList = commentForm.parentElement.querySelector('.post-comment-list');
      const postCard = commentForm.closest('.post-card');
      const commentsPanel = postCard ? postCard.querySelector('.post-comments') : null;
      const content = input ? input.value.trim() : '';

      if (!postId || !input || !submitButton || !commentList) {
        return;
      }

      if (!content) {
        input.focus();
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Posting...';

      try {
        const response = await fetch(`/feed/posts/${postId}/comments`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({ content }),
        });

        const payload = await response.json();
        if (!response.ok) {
          throw new Error(payload.error || 'Unable to save comment.');
        }

        const comments = Array.isArray(payload.comments) ? payload.comments : [];
        commentList.innerHTML = comments.map(buildCommentHtml).join('');

        if (commentsPanel) {
          commentsPanel.hidden = false;
        }

        const preview = postCard ? postCard.querySelector('.post-comment-preview') : null;
        if (preview) {
          preview.hidden = true;
        }

        if (postCard) {
          const toggleButton = postCard.querySelector('.js-comment-toggle');
          if (toggleButton) {
            toggleButton.classList.add('active');
            toggleButton.setAttribute('aria-expanded', 'true');
          }
        }

        if (postCard && typeof payload.commentCount === 'number') {
          updateCommentBadge(postCard, payload.commentCount);
        }

        if (postCard) {
          const nextCommentsPanel = postCard.querySelector('.post-comments');
          if (nextCommentsPanel && nextCommentsPanel.hidden) {
            openComments(postCard);
          }
        }

        input.value = '';
      } catch (_err) {
        // Keep UI fallback silent, matching feed behavior.
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Comment';
      }
    });
  </script>

</body>
</html>
