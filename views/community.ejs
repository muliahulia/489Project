        <div class="modal-student"><div class="modal-avatar">AB</div><span class="modal-student-name">Amara Bello</span></div>
        <div class="modal-student"><div class="modal-avatar">OZ</div><span class="modal-student-name">Olivia Zhang</span></div>
        <div class="modal-student"><div class="modal-avatar">SR</div><span class="modal-student-name">Samuel Rivera</span></div>
        <div class="modal-student"><div class="modal-avatar">HN</div><span class="modal-student-name">Hannah Nguyen</span></div>
        <div class="modal-student"><div class="modal-avatar">EF</div><span class="modal-student-name">Ethan Foster</span></div>
        <div class="modal-student"><div class="modal-avatar">MP</div><span class="modal-student-name">Mia Patel</span></div>
