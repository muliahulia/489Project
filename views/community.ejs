        <div class="modal-student"><div class="modal-avatar">PL</div><span class="modal-student-name">Patrick Lin</span></div>
        <div class="modal-student"><div class="modal-avatar">FO</div><span class="modal-student-name">Fatima Ouedraogo</span></div>
