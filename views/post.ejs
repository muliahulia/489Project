<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Post</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <style>
    /* Page-specific styles */

    .layout { display: flex; padding-top: var(--topbar-h); min-height: 100vh; }

    .sidebar {
      position: fixed; top: var(--topbar-h); left: 0; bottom: 0;
      width: var(--sidebar-w);
      background: #fff; border-right: 1px solid var(--border);
      padding: 1.5rem 0; overflow-y: auto; z-index: 90;
    }
    .sidebar-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #9aaabb; padding: 0.5rem 1.25rem; margin-top: 0.75rem; }
    .sidebar a { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 1.25rem; font-size: 0.88rem; color: var(--text-muted); border-left: 3px solid transparent; transition: all 0.15s; }
    .sidebar a:hover { background: var(--cream); color: var(--text-dark); }
    .sidebar a.active { background: rgba(201,168,76,0.1); color: var(--navy); font-weight: 600; border-left-color: var(--gold); }

    .main { flex: 1; margin-left: var(--sidebar-w); padding: 2rem; }
    .page-header { margin-bottom: 1.75rem; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 700; }
    .page-subtitle { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.25rem; }

    .page-header { width: 100%; max-width: 720px; margin: 0 auto 1.75rem; }

    /* Post Card */
    .post-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      width: 100%;
      max-width: 720px;
      position: relative;
      margin: 0 auto;
    }

    /* Action buttons (top-right corner) */
    .post-actions {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      display: flex;
      gap: 0.5rem;
    }

    .post-action-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--cream);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      color: var(--text-muted);
      transition: background 0.15s, color 0.15s;
    }

    .post-action-btn:hover {
      background: var(--cream-dark);
      color: var(--navy);
    }

    /* Author row */
    .post-author {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-right: 8rem; /* leave space for action buttons */
    }

    .post-avatar {
      width: 56px; height: 56px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--border);
      flex-shrink: 0;
      background: var(--cream-dark); /* fallback if no image */
    }

    .post-author-info { display: flex; flex-direction: column; gap: 0.15rem; }

    .post-author-name {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-dark);
    }

    .post-author-name a {
      color: var(--text-dark);
      text-decoration: none;
    }

    .post-author-name a:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .post-meta {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .post-meta a {
      color: var(--text-muted);
      text-decoration: none;
    }

    .post-meta a:hover {
      color: var(--navy);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .post-community {
      font-size: 0.8rem;
      color: var(--navy);
      font-weight: 500;
    }

    .post-community a {
      color: var(--navy);
      text-decoration: none;
    }

    .post-community a:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    /* Post body lines */
    .post-body {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.6;
    }
  </style>
</head>
<body>

  <%- include('header', { initials: 'JS' }) %>

  <div class="layout">

    <aside class="sidebar">
      <div class="sidebar-label">Main</div>
      <a href="dashboard.html">🏠 Home</a>
      <a href="feed.html" class="active">📰 Feed</a>
      <a href="communities.html">👥 Communities</a>
      <a href="courses.html">📚 Courses</a>

      <div class="sidebar-label">Account</div>
      <a href="profile.html">👤 Profile</a>
      <a href="settings.html">⚙️ Settings</a>
      <a href="login.html">🚪 Log Out</a>
    </aside>

    <main class="main">

      <div class="page-header">
        <h1 class="page-title">Post</h1>
        <p class="page-subtitle">View the full post and details.</p>
      </div>

      <!-- Post Card -->
      <div class="post-card">

        <!-- Action icon buttons (top-right) -->
        <div class="post-actions">
          <button class="post-action-btn" title="Like">👍</button>
          <button class="post-action-btn" title="Comment">💬</button>
          <button class="post-action-btn" title="Bookmark">🔖</button>
        </div>

        <!-- Author info row -->
        <div class="post-author">
          <img
            src="profile-placeholder.png"
            alt="Student profile photo"
            class="post-avatar"
            onerror="this.style.background='var(--cream-dark)'; this.removeAttribute('src');"
          />
          <div class="post-author-info">
            <span class="post-author-name"><a href="#">Student Name</a></span>
            <span class="post-meta"><a href="#">March 6, 2026 at 10:32 AM</a></span>
            <span class="post-community"><a href="#">Course or Community Name</a></span>
          </div>
        </div>

        <!-- Post content -->
        <div class="post-body">
          <p>This is the first line of the post content. Students can share updates, questions, or resources with their course or community members here.</p>
          <p>A second paragraph providing more detail or context about the topic being discussed in this post.</p>
          <p>Additional lines of text continue here, giving the post room to breathe and present information clearly.</p>
          <p>A final line wrapping up the post's content or asking a question of fellow community members.</p>
        </div>

      </div>

    </main>
  </div>

</body>
</html>
