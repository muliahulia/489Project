<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <style>
    /* Page-specific styles */

    /*THis is the top part for the header*/

    /*  */

    /* buttons*/

    
    /* dashboard css */
    .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2 columns */
    gap: 1.5rem;                          
}

    @media (max-width: 768px) {
        .cards-grid {
            grid-template-columns: 1fr; 
        }
    }

    .report-banner { display: flex; flex-direction: row; background-color: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 10px; box-shadow: 0 1px 4px rgba(13,27,42,0.07); margin-bottom: 1.25rem; justify-content: space-between; align-items: center;}
  </style>
</head>
<body>



  <%- include('header', { initials: 'JS' }) %>

  <div class="layout">

    
    <%- include('sidebar', { activePage: 'reportDashboard', showAdministrative: true }) %>


    <!--Main content area — change per page --> 
    <main class="main main-pad main-wide">

      <div class="page-header">
        <h1 class="page-title">Reports</h1>
        <p class="page-subtitle">Securely view and manage user reports.</p>
        <!-- Admin Dashboard cards in 2x2 grid -->
        <div class="cards-grid">
            <div class="card">
                <div class="card-title">Report Trends</div>
                <canvas id="chart-reports"></canvas>
            </div>
            <div class="card">
                <div class="card-title">Post Reports</div>
                <div class="report-banner">
                        <div class="account-reported">Post1</div>
                        <div class="report-reason">Innapropriate content</div>
                        <button class="btn btn-secondary" onclick="window.location.href='report.html'">Details</button>
                    </div>
                    <div class="report-banner">
                        <div class="account-reported">Post</div>
                        <div class="report-reason">Spam</div>
                        <button class="btn btn-secondary" onclick="window.location.href='report.html'">Details</button>
                    </div>
                    <button class="btn btn-primary" >View More</button>
            </div>
            <div class="card">
                <div class="card-title">Community Reports</div>
                <div class="report-banner">
                        <div class="account-reported">WSU</div>
                        <div class="report-reason">Too Cool</div>
                        <button class="btn btn-secondary" onclick="window.location.href='report.html'">Details</button>
                    </div>
                    <div class="report-banner">
                        <div class="account-reported">LI</div>
                        <div class="report-reason">Spam</div>
                        <button class="btn btn-secondary" onclick="window.location.href='report.html'">Details</button>
                    </div>
                    <button class="btn btn-primary" onclick="directToSelectedTab(event)">View More</button>
            </div>
            <div class="card">
                <div class="card-title">Account Reports</div>
                <div class="report-banner">
                        <div class="account-reported">User1</div>
                        <div class="report-reason">Impersonating others</div>
                        <button class="btn btn-secondary" onclick="window.location.href='report.html'">Details</button>
                    </div>
                    <div class="report-banner">
                        <div class="account-reported">User2</div>
                        <div class="report-reason">Spam</div>
                        <button class="btn btn-secondary" onclick="window.location.href='report.html'">Details</button>
                    </div>
                    <button class="btn btn-primary" onclick="directToSelectedTab(event)">View More</button>
            </div>
        </div>
      </div>

      <div id="userReports" class="user-reports" style="display:none;">

      </div>

      <div id="communityReports" class="community-reports" style="display:none;">

      </div>

      <div id="postReports" class="post-reports" style="display:none;">

      </div>

    </main>
  </div>

</body>
</html>