<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — University Moderation</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <style>

  </style>
</head>
<body class="moderation-page">

  <%- include('header', { initials: 'LG' }) %>

  <div class="layout">

    <%- include('sidebar', {
      activePage: 'schoolModeration',
      showAdministrative: true,
      schoolModerationHref: '/SchoolModeration',
      schoolModerationLabel: 'University Moderation'
    }) %>

    <main class="main main-pad main-contained">

      <div class="page-header">
        <h1 class="page-title">University Moderation</h1>
        <p class="page-subtitle">Search for Universities and manage Communities, courses, or settings.</p>
      </div>

      <!-- University LIST -->
      <div class="card">
        <div class="card-title">Universities</div>
        <div class="University-list" id="UniversityList"></div>
      </div>

      <!-- University DETAILS -->
      <div class="card" id="UniversityFormCard" style="display:none;">
        <div class="card-title">University Details</div>

        <div class="form-row">
          <div>
            <label>University Name</label>
            <input type="text" id="UniversityName">
          </div>
        </div>

        <div class="form-row">
          <div>
            <label>Creator</label>
            <input type="text" id="UniversityCreator">
          </div>

          <div>
            <label>Status</label>
            <select id="UniversityStatus">
              <option value="active">Active</option>
              <option value="restricted">Restricted</option>
              <option value="deleted">Deleted</option>
            </select>
          </div>
        </div>

        <div class="form-actions">
          <button class="btn-secondary" onclick="cancelEdit()">Cancel</button>
          <button class="btn-primary" onclick="saveUniversity()">Save Changes</button>
        </div>
      </div>

      <!-- University POSTS / Communities -->
      <div class="card" id="UniversityPostsCard" style="display:none;">
        <div class="card-title">University Communities</div>
        <div class="post-list" id="postList"></div>
      </div>

      <!-- CREATE NEW COMMUNITY -->
      <div class="card" id="CreateCommunityCard" style="display:none;">
        <div class="card-title">Create New Community</div>

        <div class="form-row">
          <div>
            <label>Community Name</label>
            <input type="text" id="newCommunityName" placeholder="Enter community name">
          </div>
          <div>
            <label>Creator</label>
            <input type="text" id="newCommunityCreator" placeholder="Enter creator name">
          </div>
        </div>

        <div class="form-actions">
          <button class="btn-primary" onclick="createCommunity()">Create</button>
        </div>
      </div>

    </main>
  </div>

  <script>
    const communities = [
      {
        id: 1,
        name: "Washington State University",
        creator: "John Doe",
        status: "active",
        posts: [
          { id: 1, title: "EECS", author: "Alice", flagged: false },
          { id: 2, title: "LeetCode", author: "Bob", flagged: true }
        ]
      },
      {
        id: 2,
        name: "University of Washington",
        creator: "Jane Smith",
        status: "active",
        posts: [
          { id: 3, title: "Math Club", author: "Mike", flagged: false },
          { id: 4, title: "Hackathon Club", author: "Edgar", flagged: false }
        ]
      }
    ];

    const UniversityListEl = document.getElementById("UniversityList");
    const UniversityFormCard = document.getElementById("UniversityFormCard");
    const UniversityPostsCard = document.getElementById("UniversityPostsCard");
    const CreateCommunityCard = document.getElementById("CreateCommunityCard");

    let selectedUniversity = null;

    function renderCommunities(list) {
      UniversityListEl.innerHTML = "";
      list.forEach(c => {
        const div = document.createElement("div");
        div.className = "user-item";
        div.textContent = c.name;
        div.onclick = () => selectUniversity(c);
        if (selectedUniversity && selectedUniversity.id === c.id) div.classList.add("active");
        UniversityListEl.appendChild(div);
      });
    }

    function filterUsers() {
      const q = document.getElementById("searchUsers").value.toLowerCase();
      const filtered = communities.filter(c => c.name.toLowerCase().includes(q));
      renderCommunities(filtered);
    }

    function selectUniversity(University) {
      selectedUniversity = University;
      renderCommunities(communities);

      UniversityFormCard.style.display = "block";
      UniversityPostsCard.style.display = "block";
      CreateCommunityCard.style.display = "block";

      document.getElementById("UniversityName").value = University.name;
      document.getElementById("UniversityCreator").value = University.creator;
      document.getElementById("UniversityStatus").value = University.status;

      renderPosts(University.posts);
    }

    function renderPosts(posts) {
      const postList = document.getElementById("postList");
      postList.innerHTML = "";

      posts.forEach(p => {
        const div = document.createElement("div");
        div.className = "user-item";

        div.innerHTML = `<span>${p.title} - ${p.author} ${p.flagged ? "⚠️" : ""}</span>
          <button class="btn-danger" onclick="deletePost(${p.id})">Delete</button>`;
        postList.appendChild(div);
      });
    }

    function saveUniversity() {
      if (!selectedUniversity) return;
      selectedUniversity.name = document.getElementById("UniversityName").value;
      selectedUniversity.creator = document.getElementById("UniversityCreator").value;
      selectedUniversity.status = document.getElementById("UniversityStatus").value;
      renderCommunities(communities);
    }

    function cancelEdit() {
      selectedUniversity = null;
      UniversityFormCard.style.display = "none";
      UniversityPostsCard.style.display = "none";
      CreateCommunityCard.style.display = "none";
    }

    function deletePost(id) {
      if (!selectedUniversity) return;
      selectedUniversity.posts = selectedUniversity.posts.filter(p => p.id !== id);
      renderPosts(selectedUniversity.posts);
    }

    // CREATE NEW COMMUNITY
    function createCommunity() {
      if (!selectedUniversity) return;

      const name = document.getElementById("newCommunityName").value.trim();
      const creator = document.getElementById("newCommunityCreator").value.trim();

      if (!name || !creator) {
        return;
      }

      const newCommunity = { id: Date.now(), title: name, author: creator, flagged: false };
      selectedUniversity.posts.push(newCommunity);
      renderPosts(selectedUniversity.posts);

      document.getElementById("newCommunityName").value = "";
      document.getElementById("newCommunityCreator").value = "";
    }

    renderCommunities(communities);
  </script>

</body>
</html>