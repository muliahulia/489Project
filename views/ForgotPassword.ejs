<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Forgot Password</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <style>
    /* Page-specific styles */
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2.5rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 4px 24px rgba(13,27,42,0.1);
    }

    .card-top {
      border-top: 3px solid var(--gold);
      border-radius: 16px 16px 0 0;
      margin: -2.5rem -2.5rem 2rem -2.5rem;
      padding: 0;
    }

    .brand {
      margin-bottom: 1.75rem;
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--text-dark);
      margin-bottom: 0.4rem;
    }
    .subtitle {
      font-size: 0.88rem;
      color: var(--text-muted);
      margin-bottom: 1.75rem;
      line-height: 1.55;
    }

    .btn {
      margin-bottom: 1.25rem;
    }

    .back-link {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      font-size: 0.88rem;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: var(--navy); }

    /* Success state */
    .success-state { display: none; text-align: center; }
    .success-icon {
      width: 56px; height: 56px;
      background: rgba(30,126,92,0.1);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem;
      margin: 0 auto 1.25rem;
    }
    .success-state h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 0.5rem; }
    .success-state p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1.5rem; }
  </style>
</head>
<body>

  <div class="card">
    <div class="card-top"></div>

    <div class="brand">
      <div class="brand-name">UniConnect</div>
    </div>

    <div id="form-state">
      <h1>Forgot password?</h1>
      <p class="subtitle">Enter your university email and we'll send you a reset link.</p>

      <div class="field">
        <label>Email Address</label>
        <input type="email" id="email" placeholder="you@university.edu" autocomplete="email"/>
      </div>

      <button class="btn" onclick="handleSubmit()">Send Reset Link</button>
      <a href="/login" class="back-link">← Back to login</a>
    </div>

    <div class="success-state" id="success-state">
      <div class="success-icon">✉️</div>
      <h2>Check your email</h2>
      <p>We sent a password reset link to <strong id="sent-email"></strong>. Check your inbox and follow the instructions.</p>
      <a href="/login" class="back-link">← Back to login</a>
    </div>
  </div>

  <script>
    async function handleSubmit() {
      const email = document.getElementById('email').value.trim();
      if (!email) { document.getElementById('email').focus(); return; }

      const response = await fetch('/forgotpassword', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({ email }),
      });

      if (!response.ok) {
        return;
      }

      document.getElementById('sent-email').textContent = email;
      document.getElementById('form-state').style.display = 'none';
      document.getElementById('success-state').style.display = 'block';
    }
  </script>

</body>
</html>