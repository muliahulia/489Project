<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Profile</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>

  <style>
    .main { padding: 2rem; }
    .profile-column { max-width: 720px; margin: 0 auto; }

    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 1.25rem;
      overflow: hidden;
    }

    .profile-banner {
      height: 120px;
      background: linear-gradient(135deg, var(--navy), var(--navy-light));
      background-size: cover;
      background-position: center;
    }

    .profile-hero-body { padding: 0 1.75rem 1.5rem; }

    .profile-avatar {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.3rem;
      border: 4px solid white;
      margin-top: -44px;
      overflow: hidden;
    }

    .profile-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .profile-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 700;
      margin-top: 10px;
    }

    .profile-tagline { color: var(--text-muted); font-size: 0.9rem; }

    .profile-bio { margin-top: 10px; font-size: 0.93rem; }

    .profile-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 12px;
      color: var(--text-muted);
      font-size: 0.85rem;
    }
  </style>
</head>

<body>

  <% const p = profile || {}; %>

  <%- include('header', { 
    initials: (p.first_name?.[0] || 'U') + (p.last_name?.[0] || '') 
  }) %>

<div class="layout">
  <%- include('sidebar', { activePage: 'profile' }) %>

  <main class="main">
    <div class="profile-column">

      <% const initials = (p.first_name?.[0] || '') + (p.last_name?.[0] || '') || 'U'; %>

      <!-- PROFILE CARD -->
      <div class="card">

        <div class="profile-banner" <% if (profileBannerUrl) { %>style="background-image: url('<%= profileBannerUrl %>');"<% } %>></div>

        <div class="profile-hero-body">

          <div class="profile-avatar">
            <% if (profileAvatarUrl) { %>
              <img src="<%= profileAvatarUrl %>" alt="Profile photo" />
            <% } else { %>
              <%= initials.toUpperCase() %>
            <% } %>
          </div>

          <div class="profile-name">
            <%= (p.first_name || '') + ' ' + (p.last_name || '') %>
          </div>

          <div class="profile-tagline">
            <%= p.role || 'Student' %> · Washington State University
          </div>

          <p class="profile-bio">
            <%= p.bio || 'No bio added yet.' %>
          </p>

          <div class="profile-meta-row">
            <span>📍 Pullman, WA</span>
            <span>✉️ <%= p.email || 'No email' %></span>
            <span>
              📅 Joined
              <%= p.created_at ? new Date(p.created_at).toDateString() : 'N/A' %>
            </span>
          </div>

        </div>
      </div>

      <!-- OPTIONAL POSTS SECTION -->
      <div class="card" style="padding: 1.5rem;">
        <h3>Posts</h3>

        <% const feedPosts = Array.isArray(posts) ? posts : []; %>

        <% if (feedPosts.length === 0) { %>
          <p>No posts yet.</p>
        <% } %>

        <% feedPosts.forEach(post => { %>
          <div style="margin-bottom: 1rem;">
            <strong><%= post.title || 'Untitled' %></strong>
            <p><%= post.content || '' %></p>
          </div>
        <% }) %>

      </div>

    </div>
  </main>
</div>

</body>
</html>
