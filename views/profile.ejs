<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Marcus Okafor</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <%- include('tailwind-config') %>
  <style>
    /* ── Topbar ── */

    .connect-btn {
      height: 36px; padding: 0 1.1rem;
      border-radius: 8px;
      border: none;
      background: var(--navy);
      color: var(--gold);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.83rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    .connect-btn:hover { background: var(--navy-light); }

    /* ── Main ── */
    .main {
      padding: 2rem;
    }

    .profile-column {
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
    }

    /* ── Cards ── */
    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 1.25rem;
      padding: 0;
      overflow: hidden;
    }
    .card-body { padding: 1.5rem; }

    /* ── Profile Hero ── */
    .profile-banner {
      height: 120px;
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 60%, #2c5f8a 100%);
      border-radius: 14px 14px 0 0;
      position: relative;
    }
    .profile-banner::after {
      content: '';
      position: absolute; inset: 0;
      background: repeating-linear-gradient(
        45deg,
        transparent,
        transparent 18px,
        rgba(201,168,76,0.06) 18px,
        rgba(201,168,76,0.06) 19px
      );
      border-radius: inherit;
    }

    .profile-hero-body {
      padding: 0 1.75rem 1.5rem;
      position: relative;
    }

    .profile-avatar-wrap {
      margin-top: -44px;
      margin-bottom: 0.85rem;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }

    .profile-avatar {
      width: 88px; height: 88px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 1.35rem;
      display: flex; align-items: center; justify-content: center;
      border: 4px solid #fff;
      box-shadow: 0 2px 10px rgba(13,27,42,0.18);
      letter-spacing: 0.03em;
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }

    .profile-edit-btn {
      height: 36px; padding: 0 1.1rem;
      border-radius: 8px;
      border: 1.5px solid var(--border);
      background: #fff;
      color: var(--navy);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.83rem;
      font-weight: 600;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .profile-edit-btn:hover { border-color: var(--gold); background: rgba(201,168,76,0.07); }

    .profile-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.1rem;
    }

    .profile-tagline {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .profile-bio {
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.65;
      margin-bottom: 1.1rem;
    }

    .profile-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .profile-meta-item {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .profile-meta-icon { font-size: 0.9rem; }

    .profile-stats {
      display: flex;
      gap: 0;
      border-top: 1px solid var(--border);
      padding-top: 1.1rem;
    }

    .stat {
      flex: 1;
      text-align: center;
      position: relative;
    }
    .stat + .stat::before {
      content: '';
      position: absolute; left: 0; top: 10%; bottom: 10%;
      width: 1px;
      background: var(--border);
    }
    .stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 1.45rem;
      font-weight: 700;
      color: var(--navy);
      display: block;
    }
    .stat-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* ── Section title ── */
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 1rem;
      letter-spacing: 0.01em;
    }

    /* ── About list ── */
    .about-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .about-row {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      font-size: 0.88rem;
    }
    .about-icon { width: 20px; text-align: center; font-size: 1rem; color: var(--gold); flex-shrink: 0; margin-top: 1px; }
    .about-key { min-width: 110px; color: var(--text-muted); flex-shrink: 0; }
    .about-value { color: var(--text-dark); font-weight: 500; }

    /* ── Chips ── */
    .chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .chip {
      display: inline-flex; align-items: center;
      padding: 0.3rem 0.85rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 500;
      border: 1.5px solid var(--border);
      background: var(--cream);
      color: var(--navy);
    }
    .chip.gold { background: rgba(201,168,76,0.12); border-color: rgba(201,168,76,0.4); color: #7a5c00; }

    /* ── Post Cards ── */
    .post-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      position: relative;
      margin-bottom: 1.25rem;
      width: 100%;
    }

    .post-actions {
      position: absolute;
      top: 1.25rem; right: 1.25rem;
      display: flex; gap: 0.5rem;
    }
    .post-action-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--cream);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; font-size: 1rem; color: var(--text-muted);
      transition: background 0.15s, color 0.15s;
    }
    .post-action-btn:hover { background: var(--cream-dark); color: var(--navy); }

    .post-author {
      display: flex; align-items: center;
      gap: 1rem; margin-bottom: 1.25rem;
      padding-right: 8rem;
    }
    .post-avatar-initials {
      width: 56px; height: 56px;
      border-radius: 50%; flex-shrink: 0;
      background: var(--navy); color: var(--gold);
      font-weight: 700; font-size: 0.85rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid var(--border);
      letter-spacing: 0.03em;
    }
    .post-author-info { display: flex; flex-direction: column; gap: 0.15rem; }
    .post-author-name { font-weight: 600; font-size: 1rem; color: var(--text-dark); }
    .post-author-name a { color: var(--text-dark); text-decoration: none; }
    .post-author-name a:hover { text-decoration: underline; text-underline-offset: 2px; }
    .post-meta { font-size: 0.8rem; color: var(--text-muted); }
    .post-meta a { color: var(--text-muted); text-decoration: none; }
    .post-meta a:hover { color: var(--navy); text-decoration: underline; text-underline-offset: 2px; }
    .post-community { font-size: 0.8rem; color: var(--navy); font-weight: 500; }
    .post-community a { color: var(--navy); text-decoration: none; }
    .post-community a:hover { text-decoration: underline; text-underline-offset: 2px; }
    .post-body {
      display: flex; flex-direction: column; gap: 0.65rem;
      font-size: 0.93rem; color: var(--text-dark); line-height: 1.6;
    }

    /* ── Tabs ── */
    .profile-tabs {
      display: flex;
      gap: 0;
      border-bottom: 2px solid var(--border);
      margin-bottom: 1.5rem;
    }
    .tab-btn {
      padding: 0.6rem 1.25rem;
      font-size: 0.88rem;
      font-weight: 600;
      font-family: 'DM Sans', sans-serif;
      color: var(--text-muted);
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .tab-btn:hover { color: var(--navy); }
    .tab-btn.active { color: var(--navy); border-bottom-color: var(--gold); }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
  </style>
</head>
<body>

  <%- include('header', { initials: 'JB' }) %>

  <div class="layout">

    <!-- Left Sidebar -->
    <%- include('sidebar', { activePage: 'profile' }) %>

    <!-- Main Content -->
    <main class="main">
      <div class="profile-column">

        <!-- ── Profile Hero Card ── -->
        <div class="card">
          <div class="profile-banner"></div>
          <div class="profile-hero-body">

            <div class="profile-avatar-wrap">
              <div class="profile-avatar">MO</div>
              <button class="connect-btn">＋ Connect</button>
            </div>

            <div class="profile-name">Marcus Okafor</div>
            <div class="profile-tagline">B.S. Computer Science · Washington State University · Class of 2026</div>

            <p class="profile-bio">
              Senior CS student with a focus on cybersecurity and network systems. Interned at Boeing last summer working on internal tooling. Passionate about CTF competitions, Linux, and building things that are actually hard to break. Looking for full-time roles starting Fall 2026.
            </p>

            <div class="profile-meta-row">
              <span class="profile-meta-item"><span class="profile-meta-icon">📍</span> Pullman, WA</span>
              <span class="profile-meta-item"><span class="profile-meta-icon">🎓</span> WSU — Voiland College of Engineering</span>
              <span class="profile-meta-item"><span class="profile-meta-icon">📅</span> Joined August 2022</span>
              <span class="profile-meta-item"><span class="profile-meta-icon">✉️</span> marcus.okafor@wsu.edu</span>
            </div>

            <div class="profile-stats">
              <div class="stat">
                <span class="stat-value">41</span>
                <span class="stat-label">Posts</span>
              </div>
              <div class="stat">
                <span class="stat-value">8</span>
                <span class="stat-label">Courses</span>
              </div>
              <div class="stat">
                <span class="stat-value">4</span>
                <span class="stat-label">Communities</span>
              </div>
              <div class="stat">
                <span class="stat-value">112</span>
                <span class="stat-label">Connections</span>
              </div>
            </div>

          </div>
        </div>

        <!-- ── Tabs ── -->
        <div class="profile-tabs">
          <button class="tab-btn active" onclick="switchTab('about', this)">About</button>
          <button class="tab-btn" onclick="switchTab('posts', this)">Posts</button>
          <button class="tab-btn" onclick="switchTab('courses', this)">Courses</button>
          <button class="tab-btn" onclick="switchTab('communities', this)">Communities</button>
        </div>

        <!-- ── About Tab ── -->
        <div id="tab-about" class="tab-panel active">
          <div class="card card-body" style="padding: 1.5rem;">
            <div class="section-title">About</div>
            <div class="about-list">
              <div class="about-row">
                <span class="about-icon">🎓</span>
                <span class="about-key">University</span>
                <span class="about-value">Washington State University</span>
              </div>
              <div class="about-row">
                <span class="about-icon">📖</span>
                <span class="about-key">Major</span>
                <span class="about-value">Computer Science</span>
              </div>
              <div class="about-row">
                <span class="about-icon">🏷️</span>
                <span class="about-key">Year</span>
                <span class="about-value">Senior (4th year)</span>
              </div>
              <div class="about-row">
                <span class="about-icon">🗓️</span>
                <span class="about-key">Graduation</span>
                <span class="about-value">May 2026</span>
              </div>
              <div class="about-row">
                <span class="about-icon">📊</span>
                <span class="about-key">GPA</span>
                <span class="about-value">3.58 / 4.0</span>
              </div>
              <div class="about-row">
                <span class="about-icon">✉️</span>
                <span class="about-key">Email</span>
                <span class="about-value">marcus.okafor@wsu.edu</span>
              </div>
            </div>
          </div>

          <div class="card card-body" style="padding: 1.5rem;">
            <div class="section-title">Interests &amp; Skills</div>
            <div class="chips">
              <span class="chip gold">Cybersecurity</span>
              <span class="chip gold">Network Systems</span>
              <span class="chip gold">CTF Competitions</span>
              <span class="chip">Python</span>
              <span class="chip">C / C++</span>
              <span class="chip">Bash / Shell</span>
              <span class="chip">Wireshark</span>
              <span class="chip">Linux</span>
              <span class="chip">Docker</span>
              <span class="chip">Cryptography</span>
              <span class="chip">Penetration Testing</span>
              <span class="chip">SQL</span>
            </div>
          </div>
        </div>

        <!-- ── Posts Tab ── -->
        <div id="tab-posts" class="tab-panel">

          <div class="post-card">
            <div class="post-actions">
              <button class="post-action-btn" title="Like">👍</button>
              <button class="post-action-btn" title="Comment">💬</button>
              <button class="post-action-btn" title="Bookmark">🔖</button>
            </div>
            <div class="post-author">
              <div class="post-avatar-initials">MO</div>
              <div class="post-author-info">
                <span class="post-author-name"><a href="profile.html">Marcus Okafor</a></span>
                <span class="post-meta"><a href="post.html">March 5, 2026 at 10:15 AM</a></span>
                <span class="post-community"><a href="community.html">Cybersecurity Club</a></span>
              </div>
            </div>
            <div class="post-body">
              <p>Spent the weekend going through this year's PicoCTF challenges. The binary exploitation category was brutal — finally cracked the stack canary one after way too many hours.</p>
              <p>Happy to do a write-up session at the next club meeting if people are interested. Let me know if that's worth scheduling.</p>
            </div>
          </div>

          <div class="post-card">
            <div class="post-actions">
              <button class="post-action-btn" title="Like">👍</button>
              <button class="post-action-btn" title="Comment">💬</button>
              <button class="post-action-btn" title="Bookmark">🔖</button>
            </div>
            <div class="post-author">
              <div class="post-avatar-initials">MO</div>
              <div class="post-author-info">
                <span class="post-author-name"><a href="profile.html">Marcus Okafor</a></span>
                <span class="post-meta"><a href="post.html">February 24, 2026 at 5:40 PM</a></span>
                <span class="post-community"><a href="course.html">Database Systems</a></span>
              </div>
            </div>
            <div class="post-body">
              <p>Quick heads up for anyone in CPT_S 451 — the query optimization problem on HW4 has a typo in the cost formula. Professor confirmed in office hours that it should be log base 2, not natural log. Saves you some confusion.</p>
            </div>
          </div>

          <div class="post-card">
            <div class="post-actions">
              <button class="post-action-btn" title="Like">👍</button>
              <button class="post-action-btn" title="Comment">💬</button>
              <button class="post-action-btn" title="Bookmark">🔖</button>
            </div>
            <div class="post-author">
              <div class="post-avatar-initials">MO</div>
              <div class="post-author-info">
                <span class="post-author-name"><a href="profile.html">Marcus Okafor</a></span>
                <span class="post-meta"><a href="post.html">February 14, 2026 at 8:55 PM</a></span>
                <span class="post-community"><a href="community.html">Computer Science Club</a></span>
              </div>
            </div>
            <div class="post-body">
              <p>Boeing internship application tip for anyone applying this cycle: their online assessment has a heavy emphasis on data structures (trees + graphs). Less leetcode-style grinding, more understanding of tradeoffs.</p>
              <p>Went through it last year — happy to do a mock session with anyone prepping. Just DM me.</p>
            </div>
          </div>

        </div>

        <!-- ── Courses Tab ── -->
        <div id="tab-courses" class="tab-panel">
          <div class="card card-body" style="padding: 1.5rem;">
            <div class="section-title">Enrolled Courses — Spring 2026</div>
            <div class="chips">
              <a href="course.html" class="chip gold">CPT_S 451 · Database Systems</a>
              <a href="course.html" class="chip gold">CPT_S 424 · Network Security</a>
              <a href="course.html" class="chip gold">CPT_S 460 · Operating Systems</a>
              <a href="course.html" class="chip">CPT_S 415 · Software Testing</a>
            </div>
          </div>
          <div class="card card-body" style="padding: 1.5rem;">
            <div class="section-title">Previous Courses</div>
            <div class="chips">
              <a href="course.html" class="chip">CPT_S 101 · Intro to Programming</a>
              <a href="course.html" class="chip">CPT_S 223 · Data Structures</a>
              <a href="course.html" class="chip">CPT_S 350 · Systems Programming</a>
              <a href="course.html" class="chip">CPT_S 317 · Automata &amp; Formal Languages</a>
            </div>
          </div>
        </div>

        <!-- ── Communities Tab ── -->
        <div id="tab-communities" class="tab-panel">
          <div class="card card-body" style="padding: 1.5rem;">
            <div class="section-title">Communities</div>
            <div class="chips">
              <a href="community.html" class="chip gold">� Cybersecurity Club</a>
              <a href="community.html" class="chip gold">👥 Computer Science Club</a>
              <a href="community.html" class="chip">💻 HackWSU</a>
              <a href="community.html" class="chip">📐 Algorithms Study Group</a>
            </div>
          </div>
        </div>

      </div><!-- /.profile-column -->
    </main>

  </div><!-- /.layout -->

  <script>
    function switchTab(name, btn) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      btn.classList.add('active');
    }
  </script>

  <%- include('footer', { footerLayout: 'sidebarLeft' }) %>

</body>
</html>
