<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Courses</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <!-- Tailwind required for footer -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: '#0d1b2a',
            'navy-mid': '#1a2e45',
            'navy-light': '#243b55',
            gold: '#c9a84c',
            'gold-light': '#e8c97a',
            cream: '#f5f0e8',
            'cream-dark': '#ede5d6',
          },
          fontFamily: {
            'serif': ['Playfair Display', 'serif'],
            'sans': ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    /* ── Topbar ── */

    /* ── Layout ── */
    .layout {
      display: flex;
      padding-top: var(--topbar-h);
      min-height: 100vh;
    }


    /* ── Main ── */
    .main {
      flex: 1;
      margin-left: var(--sidebar-w);
      padding: 2rem;
      min-width: 0;
    }

    .courses-column {
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
    }

    /* ── Page title ── */
    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 1.5rem;
    }

    /* ── Course Card ── */
    .course-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin-bottom: 1rem;
      text-decoration: none;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    .course-card:hover {
      border-color: var(--gold);
      box-shadow: 0 2px 10px rgba(201,168,76,0.15);
    }

    /* ── Course icon circle ── */
    .course-avatar {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.68rem;
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      line-height: 1.3;
      flex-shrink: 0;
      border: 2px solid var(--border);
    }

    /* Color variants */
    .course-avatar.v2 { background: var(--navy-mid); }
    .course-avatar.v3 { background: var(--navy-light); }
    .course-avatar.v4 { background: #2c4a6e; }
    .course-avatar.v5 { background: #1e3a52; }
    .course-avatar.v6 { background: #163044; }
    .course-avatar.v7 { background: #0f2233; }

    /* ── Course info ── */
    .course-info {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      min-width: 0;
    }

    .course-name-row {
      display: flex;
      align-items: baseline;
      gap: 0.65rem;
      flex-wrap: wrap;
    }

    .course-name {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-dark);
    }

    .course-code {
      font-size: 0.78rem;
      color: var(--text-muted);
      font-family: 'DM Sans', monospace;
    }

    .course-meta {
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    .course-description {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
  </style>
</head>
<body>

  <%- include('header', { initials: 'JB' }) %>

  <div class="layout">

    <!-- Left Sidebar -->
    <%- include('sidebar', { activePage: 'courses' }) %>

    <!-- Main Content -->
    <main class="main">
      <div class="courses-column">

        <h1 class="page-title">Courses at WSU</h1>

        <!-- 1 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar">CPT_S<br>489</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Software Engineering</span>
              <span class="course-code">CPT_S 489</span>
            </div>
            <span class="course-meta">Dr. Marcus Henderson · 43 students · Spring 2026</span>
            <p class="course-description">Covers the software development lifecycle, requirements engineering, design patterns, testing strategies, and team-based project management using modern tools and agile methodologies.</p>
          </div>
        </a>

        <!-- 2 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar v2">CPT_S<br>451</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Database Systems</span>
              <span class="course-code">CPT_S 451</span>
            </div>
            <span class="course-meta">Dr. Priya Sharma · 38 students · Spring 2026</span>
            <p class="course-description">An in-depth study of relational database design, SQL, query optimization, transaction management, normalization, and an introduction to NoSQL and distributed data systems.</p>
          </div>
        </a>

        <!-- 3 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar v3">CPT_S<br>350</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Systems Programming</span>
              <span class="course-code">CPT_S 350</span>
            </div>
            <span class="course-meta">Dr. Alan Torres · 51 students · Spring 2026</span>
            <p class="course-description">Explores low-level programming in C and C++, memory management, process control, file systems, inter-process communication, and operating system interfaces.</p>
          </div>
        </a>

        <!-- 4 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar v4">MATH<br>315</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Discrete Mathematics</span>
              <span class="course-code">MATH 315</span>
            </div>
            <span class="course-meta">Dr. Linda Kowalski · 60 students · Spring 2026</span>
            <p class="course-description">Covers logic, set theory, combinatorics, graph theory, proof techniques, and their applications in computer science including algorithm analysis and cryptography.</p>
          </div>
        </a>

        <!-- 5 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar v5">CPT_S<br>223</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Data Structures &amp; Algorithms</span>
              <span class="course-code">CPT_S 223</span>
            </div>
            <span class="course-meta">Dr. James O'Brien · 72 students · Fall 2025</span>
            <p class="course-description">Fundamental data structures including trees, graphs, hash tables, and heaps, paired with algorithm design paradigms such as divide and conquer, dynamic programming, and greedy methods.</p>
          </div>
        </a>

        <!-- 6 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar v6">CPT_S<br>427</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Machine Learning</span>
              <span class="course-code">CPT_S 427</span>
            </div>
            <span class="course-meta">Dr. Nadia Patel · 44 students · Fall 2025</span>
            <p class="course-description">Introduction to supervised and unsupervised learning, neural networks, model evaluation, regularization, and practical implementation using Python-based ML frameworks.</p>
          </div>
        </a>

        <!-- 7 -->
        <a href="course.html" class="course-card">
          <div class="course-avatar v7">CPT_S<br>101</div>
          <div class="course-info">
            <div class="course-name-row">
              <span class="course-name">Intro to Programming</span>
              <span class="course-code">CPT_S 101</span>
            </div>
            <span class="course-meta">Dr. Sara Nguyen · 98 students · Fall 2023</span>
            <p class="course-description">Foundational programming concepts using Python including variables, control flow, functions, file I/O, and basic object-oriented principles. Designed for students with no prior coding experience.</p>
          </div>
        </a>

      </div><!-- /.courses-column -->
    </main>

  </div><!-- /.layout -->

  <!-- Footer -->
  <footer class="bg-cream relative z-10 py-8 sm:py-12 border-t-2 border-gold/20" style="margin-left: var(--sidebar-w);">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8 text-center md:text-left">

        <div>
          <h3 class="font-serif text-lg sm:text-xl font-bold text-navy mb-3">About UniConnect</h3>
          <p class="text-navy/70 text-sm leading-relaxed">
            A verified academic platform connecting students, faculty, and administrators across universities.
          </p>
        </div>

        <div>
          <h3 class="font-serif text-lg sm:text-xl font-bold text-navy mb-3">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="#" class="text-navy/70 hover:text-gold transition">Privacy Policy</a></li>
            <li><a href="#" class="text-navy/70 hover:text-gold transition">Terms of Service</a></li>
            <li><a href="#" class="text-navy/70 hover:text-gold transition">Contact Us</a></li>
            <li><a href="#" class="text-navy/70 hover:text-gold transition">Help Center</a></li>
          </ul>
        </div>

        <div>
          <h3 class="font-serif text-lg sm:text-xl font-bold text-navy mb-3">Get in Touch</h3>
          <p class="text-navy/70 text-sm leading-relaxed">
            Have questions? Reach out to our support team at<br class="hidden sm:inline">
            <a href="mailto:support@uniconnect.edu" class="text-gold hover:text-gold-light transition break-all sm:break-normal">support@uniconnect.edu</a>
          </p>
        </div>

      </div>
      <div class="mt-6 sm:mt-8 pt-4 sm:pt-6 border-t border-navy/20 text-center">
        <p class="text-navy/60 text-xs sm:text-sm">&copy; 2026 UniConnect. All rights reserved.</p>
      </div>
    </div>
  </footer>

</body>
</html>
