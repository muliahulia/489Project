<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Courses</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>
  <style>
    .main {
      padding: 2rem;
    }

    .courses-column {
      width: 100%;
      max-width: 760px;
      margin: 0 auto;
    }

    .page-header {
      margin-bottom: 1.5rem;
    }

    .page-header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .page-title {
      color: var(--text-dark);
      margin-bottom: 0.35rem;
    }

    .page-subtitle {
      color: var(--text-muted);
      font-size: 0.92rem;
      line-height: 1.6;
      margin: 0;
    }

    .info-banner,
    .empty-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.15rem;
      color: var(--text-muted);
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 1rem;
    }

    .info-banner.error {
      border-color: rgba(176, 58, 46, 0.25);
      background: rgba(176, 58, 46, 0.05);
      color: #8f2f25;
    }

    .cta-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.7rem 1rem;
      border-radius: 10px;
      background: var(--navy);
      color: var(--gold);
      font-size: 0.86rem;
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.15s ease;
    }

    .cta-link:hover {
      background: var(--navy-mid);
    }

    .course-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      margin-bottom: 1rem;
      transition: box-shadow 0.15s, border-color 0.15s;
    }

    .course-section {
      margin-top: 1.75rem;
    }

    .course-section:first-of-type {
      margin-top: 0;
    }

    .section-title {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #8da0b3;
      margin: 0 0 0.8rem;
    }

    .course-card:hover {
      border-color: var(--gold);
      box-shadow: 0 2px 10px rgba(201,168,76,0.15);
    }

    .course-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.78rem;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      line-height: 1.3;
      flex-shrink: 0;
      border: 2px solid var(--border);
    }

    .course-avatar.v1 { background: var(--navy); }
    .course-avatar.v2 { background: var(--navy-mid); }
    .course-avatar.v3 { background: var(--navy-light); }
    .course-avatar.v4 { background: #2c4a6e; }
    .course-avatar.v5 { background: #1e3a52; }
    .course-avatar.v6 { background: #163044; }
    .course-avatar.v7 { background: #0f2233; }

    .course-info {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      min-width: 0;
      flex: 1;
    }

    .course-name-row {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      flex-wrap: wrap;
    }

    .course-name-link {
      color: inherit;
      text-decoration: none;
    }

    .course-name-link:hover .course-name {
      color: var(--navy);
    }

    .course-name {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-dark);
      transition: color 0.15s;
    }

    .course-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.28rem 0.6rem;
      border-radius: 999px;
      font-size: 0.76rem;
      font-weight: 600;
      border: 1px solid var(--border);
      background: var(--cream);
      color: var(--text-muted);
    }

    .course-badge.enrolled {
      background: rgba(201,168,76,0.14);
      color: var(--navy);
      border-color: rgba(201,168,76,0.35);
    }

    .course-badge.instructor {
      background: rgba(13,27,42,0.08);
      color: var(--navy);
      border-color: rgba(13,27,42,0.16);
    }

    .course-meta {
      font-size: 0.82rem;
      color: var(--text-muted);
      line-height: 1.5;
    }

    .course-description {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.6;
      margin: 0;
    }

    .course-actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 0.3rem;
    }

    .btn-link,
    .btn-submit {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.84rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      padding: 0.55rem 0.95rem;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

    .btn-link {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--navy);
    }

    .btn-link:hover {
      border-color: var(--navy);
      background: var(--cream);
    }

    .btn-submit {
      border: none;
      background: var(--navy);
      color: var(--gold);
    }

    .btn-submit.secondary {
      background: var(--cream);
      border: 1px solid var(--border);
      color: var(--text-dark);
    }

    .btn-submit:hover {
      background: var(--navy-mid);
    }

    .btn-submit.secondary:hover {
      background: #f4efe5;
    }
  </style>
</head>
<body>

  <%- include('header', { user }) %>

  <div class="layout">

    <%- include('sidebar', { activePage: 'courses' }) %>

    <main class="main">
      <div class="courses-column">
        <% const ownedCourseList = Array.isArray(myCourses) ? myCourses : []; %>
        <% const availableCourseList = Array.isArray(availableCourses) ? availableCourses : []; %>
        <% const subtitle = schoolName ? `Browse courses for ${schoolName}. Join a course to unlock its discussion feed.` : 'Browse your courses and manage your enrollment.'; %>

        <div class="page-header">
          <div class="page-header-row">
            <div>
              <h1 class="page-title">Courses</h1>
              <p class="page-subtitle"><%= subtitle %></p>
            </div>

            <% if (canCreateCourse) { %>
              <a class="cta-link" href="/courses/create">Create course</a>
            <% } %>
          </div>
        </div>

        <% if (pageError) { %>
          <div class="info-banner error"><%= pageError %></div>
        <% } %>

        <% if (directoryMessage) { %>
          <div class="info-banner"><%= directoryMessage %></div>
        <% } %>

        <section class="course-section">
          <h2 class="section-title">My Courses</h2>

          <% if (ownedCourseList.length === 0) { %>
            <div class="empty-card">You have not joined or created any courses yet.</div>
          <% } %>

          <% ownedCourseList.forEach((course) => { %>
            <div class="course-card">
              <div class="course-avatar <%= course.avatarClass %>"><%= course.bubbleText %></div>
              <div class="course-info">
                <div class="course-name-row">
                  <a href="<%= course.detailHref %>" class="course-name-link">
                    <span class="course-name"><%= course.name %></span>
                  </a>
                  <span class="course-badge <%= course.isInstructor ? 'instructor' : course.isEnrolled ? 'enrolled' : '' %>">
                    <%= course.membershipLabel %>
                  </span>
                </div>
                <span class="course-meta"><%= course.instructorName %> · <%= course.memberLabel %></span>
                <p class="course-description"><%= course.description %></p>
                <div class="course-actions">
                  <a href="<%= course.detailHref %>" class="btn-link">View course</a>
                  <% if (course.canManage) { %>
                    <a href="<%= course.manageHref %>" class="btn-link">Manage course</a>
                  <% } %>

                  <% if (!course.isInstructor && course.isEnrolled) { %>
                    <form method="post" action="/courses/<%= course.id %>/leave">
                      <input type="hidden" name="redirectTo" value="/courses" />
                      <button class="btn-submit secondary" type="submit">Leave course</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </section>

        <section class="course-section">
          <h2 class="section-title">Courses on UniConnect</h2>

          <% if (availableCourseList.length === 0) { %>
            <div class="empty-card">No additional courses are available to join right now.</div>
          <% } %>

          <% availableCourseList.forEach((course) => { %>
            <div class="course-card">
              <div class="course-avatar <%= course.avatarClass %>"><%= course.bubbleText %></div>
              <div class="course-info">
                <div class="course-name-row">
                  <a href="<%= course.detailHref %>" class="course-name-link">
                    <span class="course-name"><%= course.name %></span>
                  </a>
                  <span class="course-badge"><%= course.membershipLabel %></span>
                </div>
                <span class="course-meta"><%= course.instructorName %> · <%= course.memberLabel %></span>
                <p class="course-description"><%= course.description %></p>
                <div class="course-actions">
                  <a href="<%= course.detailHref %>" class="btn-link">View course</a>
                  <% if (course.canManage) { %>
                    <a href="<%= course.manageHref %>" class="btn-link">Manage course</a>
                  <% } %>
                  <form method="post" action="/courses/<%= course.id %>/join">
                    <input type="hidden" name="redirectTo" value="/courses" />
                    <button class="btn-submit" type="submit">Join course</button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </section>
      </div>
    </main>

  </div>

  <%- include('footer', { footerLayout: 'sidebarLeft' }) %>

</body>
</html>
