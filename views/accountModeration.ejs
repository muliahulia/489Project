<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Account Moderation</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <style>
    /* Page-specific styles — same as Settings page */

    .layout { display: flex; padding-top: var(--topbar-h); min-height: 100vh; }
    .main { flex: 1; margin-left: var(--sidebar-w); padding: 2rem; max-width: none; }
    .page-header { margin-bottom: 1.75rem; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 700; }
    .page-subtitle { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.25rem; }

    /* Account moderation styles — matching Settings page cards/toggles */
    .card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 1.75rem; box-shadow: 0 1px 4px rgba(13,27,42,0.07); margin-bottom: 1.25rem; }
    .card-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border); }

    .user-list { max-height: 300px; overflow-y: auto; margin-bottom: 1rem; }
    .user-item { padding: 0.85rem 1rem; border-bottom: 1px solid var(--border); cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .user-item:last-child { border-bottom: none; }
    .user-item.active {
        background: rgba(201,168,76,0.15);
        border-left: 3px solid var(--gold);
        font-weight: 600;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem; }
    .form-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1rem; }
    .btn-primary { background: var(--gold); color: var(--navy); padding: 0.6rem 1.4rem; border-radius: 8px; font-size: 0.88rem; cursor: pointer; border: none; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-secondary { background: var(--cream); color: var(--text-dark); padding: 0.55rem 1.25rem; border-radius: 8px; font-size: 0.85rem; border: none; cursor: pointer; }
    .btn-danger { background: var(--error); color: #fff; padding: 0.55rem 1.25rem; border-radius: 8px; font-size: 0.85rem; border: none; cursor: pointer; }

    input, select { width: 100%; padding: 0.55rem 0.75rem; border-radius: 8px; border: 1px solid var(--border); font-family: 'DM Sans', sans-serif; margin-top: 0.25rem; }
  </style>
</head>
<body>

  <%- include('header', { initials: 'LG' }) %>

  <div class="layout">

    <%- include('sidebar', { activePage: 'accountModeration', showAdministrative: true }) %>

    <!-- MAIN content area -->
    <main class="main">

      <div class="page-header">
        <h1 class="page-title">Account Moderation</h1>
        <p class="page-subtitle">Search for a user and update account settings.</p>
      </div>

      <!-- Save confirmation -->
        <div class="save-alert" id="save-alert" style="display:none;">✅ Changes saved.</div>

      <!-- USER LIST CARD -->
      <div class="card">
        <div class="card-title">Users</div>
        <div class="user-list" id="userList"></div>
      </div>

      <!-- USER DETAIL CARD -->
      <div class="card" id="userFormCard" style="display:none;">
        <div class="card-title">Edit User</div>
        <div class="form-row">
          <div>
            <label>Username</label>
            <input type="text" id="username">
          </div>
          <div>
            <label>Email</label>
            <input type="email" id="email">
          </div>
        </div>
        <div class="form-row">
          <div>
            <label>Role</label>
            <select id="role">
              <option value="user">User</option>
              <option value="moderator">Moderator</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <div>
            <label>Status</label>
            <select id="status">
              <option value="active">Active</option>
              <option value="suspended">Suspended</option>
              <option value="deleted">Deleted</option>
            </select>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn-secondary" onclick="cancelEdit()">Cancel</button>
          <button class="btn-primary" onclick="saveUser()">Save Changes</button>
        </div>
      </div>

    </main>
  </div>

  <script>
    const users = [
      { id:1, username:"John Doe", email:"john@example.com", role:"user", status:"active" },
      { id:2, username:"Jane Smith", email:"jane@example.com", role:"moderator", status:"active" },
      { id:3, username:"Alice Johnson", email:"alice@example.com", role:"user", status:"suspended" }
    ];

    const userListEl = document.getElementById('userList');
    const userFormCard = document.getElementById('userFormCard');
    let selectedUser = null;

    function renderUsers(list) {
      userListEl.innerHTML = '';
      list.forEach(u => {
        const div = document.createElement('div');
        div.className = 'user-item';
        div.textContent = `${u.username} (${u.email})`;
        div.onclick = () => selectUser(u, div);
        if(selectedUser && selectedUser.id === u.id) div.classList.add('active');
        userListEl.appendChild(div);
      });
    }

    function filterUsers() {
      const q = document.getElementById('searchUsers').value.toLowerCase();
      const filtered = users.filter(u => u.username.toLowerCase().includes(q) || u.email.toLowerCase().includes(q));
      renderUsers(filtered);
    }

    function selectUser(user, element) {
      selectedUser = user;
      renderUsers(users);
      userFormCard.style.display = 'block';
      document.getElementById('username').value = user.username;
      document.getElementById('email').value = user.email;
      document.getElementById('role').value = user.role;
      document.getElementById('status').value = user.status;
    }

    function saveUser() {
      if(!selectedUser) return;
      selectedUser.username = document.getElementById('username').value;
      selectedUser.email = document.getElementById('email').value;
      selectedUser.role = document.getElementById('role').value;
      selectedUser.status = document.getElementById('status').value;
      document.getElementById('save-alert').style.display = 'flex';
      setTimeout(()=>document.getElementById('save-alert').style.display='none', 3000);
      renderUsers(users);
    }

    function cancelEdit() {
      selectedUser = null;
      userFormCard.style.display = 'none';
      renderUsers(users);
    }

    renderUsers(users);
  </script>

</body>
</html>