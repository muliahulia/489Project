<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Communities</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <!-- Tailwind required for footer -->
  <%- include('tailwind-config') %>
  <style>
    /* ── Topbar ── */

    /* ── Main ── */
    .main {
      padding: 2rem;
    }

    .communities-column {
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
    }

    /* ── Page header row ── */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    /* ── Page title ── */
    .page-title {
      color: var(--text-dark);
      margin-bottom: 0;
    }

    /* ── Create button ── */
    .btn-create {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1.1rem;
      background: var(--navy);
      color: var(--gold);
      border: none;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s, box-shadow 0.15s;
      white-space: nowrap;
    }
    .btn-create:hover {
      background: var(--navy-mid);
      box-shadow: 0 3px 10px rgba(13,27,42,0.18);
    }

    /* ── Community Card ── */
    .community-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin-bottom: 1rem;
      text-decoration: none;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    .community-card:hover {
      border-color: var(--gold);
      box-shadow: 0 2px 10px rgba(201,168,76,0.15);
    }

    /* ── Club image circle ── */
    .club-avatar {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.72rem;
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      line-height: 1.3;
      flex-shrink: 0;
      border: 2px solid var(--border);
    }

    /* Color variants */
    .club-avatar.v2 { background: var(--navy-mid); }
    .club-avatar.v3 { background: var(--navy-light); }
    .club-avatar.v4 { background: #2c4a6e; }
    .club-avatar.v5 { background: #1e3a52; }
    .club-avatar.v6 { background: #163044; }
    .club-avatar.v7 { background: #0f2233; }
    .club-avatar.v8 { background: #20364f; }

    /* ── Club info ── */
    .club-info {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      min-width: 0;
    }

    .club-name-row {
      display: flex;
      align-items: baseline;
      gap: 0.65rem;
      flex-wrap: wrap;
    }

    .club-name {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-dark);
    }

    .club-members {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .club-description {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
  </style>
</head>
<body>

  <%- include('header', { initials: 'LG' }) %>

  <div class="layout">

    <!-- Left Sidebar -->
    <%- include('sidebar', { activePage: 'communities' }) %>

    <!-- Main Content -->
    <main class="main">
      <div class="communities-column">

        <div class="page-header">
          <h1 class="page-title">Communities at WSU</h1>
          <a href="create-community.html" class="btn-create">+ Create Community</a>
        </div>

        <!-- 1 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar">CS<br>Club</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Computer Science Club</span>
              <span class="club-members">142 members</span>
            </div>
            <p class="club-description">A community for CS students to connect, collaborate, and grow. We host weekly talks, coding challenges, and networking events with industry professionals throughout the semester.</p>
          </div>
        </a>

        <!-- 2 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v2">Hack<br>WSU</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">HackWSU</span>
              <span class="club-members">89 members</span>
            </div>
            <p class="club-description">WSU's official hackathon organization. We run HackWSU each spring and host smaller build nights and workshops year-round to help students develop real-world project experience.</p>
          </div>
        </a>

        <!-- 3 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v3">AI<br>ML</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">AI &amp; ML Interest Group</span>
              <span class="club-members">67 members</span>
            </div>
            <p class="club-description">Dedicated to exploring artificial intelligence and machine learning through paper readings, project showcases, and guest lectures from researchers and engineers in the field.</p>
          </div>
        </a>

        <!-- 4 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v4">Open<br>Src</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Open Source Initiative</span>
              <span class="club-members">54 members</span>
            </div>
            <p class="club-description">We contribute to open-source projects together and help members make their first pull requests. Great for building a portfolio and learning collaborative software development practices.</p>
          </div>
        </a>

        <!-- 5 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v5">Women<br>CS</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Women in Computer Science</span>
              <span class="club-members">78 members</span>
            </div>
            <p class="club-description">Supporting and empowering women and non-binary students in tech through mentorship, community building, career panels, and networking opportunities with local and national companies.</p>
          </div>
        </a>

        <!-- 6 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v6">Cyber<br>Sec</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Cybersecurity Club</span>
              <span class="club-members">61 members</span>
            </div>
            <p class="club-description">Focused on ethical hacking, CTF competitions, and security research. We compete in national Capture the Flag events and run hands-on workshops covering topics from network security to cryptography.</p>
          </div>
        </a>

        <!-- 7 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v7">Game<br>Dev</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Game Development Club</span>
              <span class="club-members">95 members</span>
            </div>
            <p class="club-description">A creative space for students interested in building games. We use Unity, Unreal, and Godot, participate in game jams, and collaborate on original projects across programming, art, and design.</p>
          </div>
        </a>

        <!-- 8 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar v8">Algo<br>SG</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Algorithms Study Group</span>
              <span class="club-members">43 members</span>
            </div>
            <p class="club-description">Meet weekly to work through algorithm problems, review data structures, and prepare for technical interviews. All skill levels are welcome — bring your laptop and your questions.</p>
          </div>
        </a>

      </div><!-- /.communities-column -->
    </main>

  </div><!-- /.layout -->

  <%- include('footer', { footerLayout: 'sidebarLeft' }) %>

</body>
</html>
