<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Communities</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="style.css"/>
  <!-- Tailwind required for footer -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: '#0d1b2a',
            'navy-mid': '#1a2e45',
            'navy-light': '#243b55',
            gold: '#c9a84c',
            'gold-light': '#e8c97a',
            cream: '#f5f0e8',
            'cream-dark': '#ede5d6',
          },
          fontFamily: {
            'serif': ['Playfair Display', 'serif'],
            'sans': ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    /* ── Topbar ── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0;
      height: var(--topbar-h);
      background: var(--navy);
      border-bottom: 2px solid var(--gold);
      display: flex; align-items: center;
      padding: 0 1.5rem; gap: 1rem; z-index: 100;
    }
    .topbar-brand { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--gold); }
    .topbar-search { flex: 1; max-width: 380px; margin-left: 1.5rem; position: relative; }
    .topbar-search input {
      width: 100%; padding: 0.4rem 1rem 0.4rem 2.2rem;
      border-radius: 999px; border: 1.5px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.07); color: #fff;
      font-family: 'DM Sans', sans-serif; font-size: 0.85rem; outline: none;
    }
    .topbar-search input::placeholder { color: rgba(255,255,255,0.35); }
    .topbar-search input:focus { border-color: var(--gold); }
    .topbar-search span { position: absolute; left: 0.7rem; top: 50%; transform: translateY(-50%); font-size: 0.8rem; color: rgba(255,255,255,0.4); }
    .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 0.75rem; }
    .topbar-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--gold); color: var(--navy);
      font-weight: 700; font-size: 0.8rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid rgba(201,168,76,0.4); cursor: pointer;
    }

    /* ── Layout ── */
    .layout {
      display: flex;
      padding-top: var(--topbar-h);
      min-height: 100vh;
    }

    /* ── Left Sidebar ── */
    .sidebar {
      position: fixed; top: var(--topbar-h); left: 0; bottom: 0;
      width: var(--sidebar-w);
      background: #fff; border-right: 1px solid var(--border);
      padding: 1.5rem 0; overflow-y: auto; z-index: 90;
    }
    .sidebar-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #9aaabb; padding: 0.5rem 1.25rem; margin-top: 0.75rem; }
    .sidebar a { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 1.25rem; font-size: 0.88rem; color: var(--text-muted); border-left: 3px solid transparent; transition: all 0.15s; }
    .sidebar a:hover { background: var(--cream); color: var(--text-dark); }
    .sidebar a.active { background: rgba(201,168,76,0.1); color: var(--navy); font-weight: 600; border-left-color: var(--gold); }

    /* ── Main ── */
    .main {
      flex: 1;
      margin-left: var(--sidebar-w);
      padding: 2rem;
      min-width: 0;
    }

    .communities-column {
      width: 100%;
      max-width: 720px;
      margin: 0 auto;
    }

    /* ── Page header row ── */
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    /* ── Page title ── */
    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0;
    }

    /* ── Create button ── */
    .btn-create {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.55rem 1.1rem;
      background: var(--navy);
      color: var(--gold);
      border: none;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.15s, box-shadow 0.15s;
      white-space: nowrap;
    }
    .btn-create:hover {
      background: var(--navy-mid);
      box-shadow: 0 3px 10px rgba(13,27,42,0.18);
    }

    /* ── Community Card ── */
    .community-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin-bottom: 1rem;
      text-decoration: none;
      transition: box-shadow 0.15s, border-color 0.15s;
    }
    .community-card:hover {
      border-color: var(--gold);
      box-shadow: 0 2px 10px rgba(201,168,76,0.15);
    }

    /* ── Club image circle ── */
    .club-avatar {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.72rem;
      display: flex; align-items: center; justify-content: center;
      text-align: center;
      line-height: 1.3;
      flex-shrink: 0;
      border: 2px solid var(--border);
    }

    /* Color variants */
    .club-avatar.v2 { background: var(--navy-mid); }
    .club-avatar.v3 { background: var(--navy-light); }
    .club-avatar.v4 { background: #2c4a6e; }
    .club-avatar.v5 { background: #1e3a52; }
    .club-avatar.v6 { background: #163044; }
    .club-avatar.v7 { background: #0f2233; }
    .club-avatar.v8 { background: #20364f; }

    /* ── Club info ── */
    .club-info {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      min-width: 0;
    }

    .club-name-row {
      display: flex;
      align-items: baseline;
      gap: 0.65rem;
      flex-wrap: wrap;
    }

    .club-name {
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-dark);
    }

    .club-members {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .club-description {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.55;
    }
  </style>
</head>
<body>

  <!-- TOPBAR -->
  <nav class="topbar">
    <div class="topbar-brand">UniConnect</div>
    <div class="topbar-search">
      <span>🔍</span>
      <input type="text" placeholder="Search..."/>
    </div>
    <div class="topbar-right">
      <div class="topbar-avatar">JB</div>
    </div>
  </nav>

  <div class="layout">

    <!-- Left Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-label">Main</div>
      <a href="dashboard.html">🏠 Home</a>
      <a href="feed.html">📰 Feed</a>
      <a href="communities.html" class="active">👥 Communities</a>
      <a href="courses.html">📚 Courses</a>

      <div class="sidebar-label">Account</div>
      <a href="profile.html">👤 Profile</a>
      <a href="settings.html">⚙️ Settings</a>
      <a href="login.html">🚪 Log Out</a>
    </aside>

    <!-- Main Content -->
    <main class="main">
      <div class="communities-column">

        <div class="page-header">
          <h1 class="page-title">Communities at WSU</h1>
          <a href="create-community.html" class="btn-create">+ Create Community</a>
        </div>

        <!-- 1 -->
        <a href="community.html" class="community-card">
          <div class="club-avatar">CS<br>Club</div>
          <div class="club-info">
            <div class="club-name-row">
              <span class="club-name">Computer Science Club</span>
              <span class="club-members">142 members</span>
