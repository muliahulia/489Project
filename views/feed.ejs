<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect — Feed</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <!-- Tailwind required for footer -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: '#0d1b2a',
            'navy-mid': '#1a2e45',
            'navy-light': '#243b55',
            gold: '#c9a84c',
            'gold-light': '#e8c97a',
            cream: '#f5f0e8',
            'cream-dark': '#ede5d6',
          },
          fontFamily: {
            'serif': ['Playfair Display', 'serif'],
            'sans': ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    /* ── Topbar ── */

    /* ── Layout ── */
    .layout {
      display: flex;
      padding-top: var(--topbar-h);
      min-height: 100vh;
    }

    /* ── Left Sidebar ── */
    .sidebar {
      position: fixed; top: var(--topbar-h); left: 0; bottom: 0;
      width: var(--sidebar-w);
      background: #fff; border-right: 1px solid var(--border);
      padding: 1.5rem 0; overflow-y: auto; z-index: 90;
    }
    .sidebar-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #9aaabb; padding: 0.5rem 1.25rem; margin-top: 0.75rem; }
    .sidebar a { display: flex; align-items: center; gap: 0.75rem; padding: 0.6rem 1.25rem; font-size: 0.88rem; color: var(--text-muted); border-left: 3px solid transparent; transition: all 0.15s; }
    .sidebar a:hover { background: var(--cream); color: var(--text-dark); }
    .sidebar a.active { background: rgba(201,168,76,0.1); color: var(--navy); font-weight: 600; border-left-color: var(--gold); }

    /* ── Main content ── */
    .main {
      flex: 1;
      margin-left: var(--sidebar-w);
      margin-right: 260px; /* right sidebar width */
      padding: 2rem;
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* Constrain feed to a readable fixed width */
    .feed-column {
      width: 100%;
      max-width: 620px;
    }

    .page-header { margin-bottom: 1.75rem; }
    .page-title { font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 700; }
    .page-subtitle { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.25rem; }

    /* ── Create Post Box ── */
    .create-post {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 1.25rem;
    }

    .create-post-top {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .create-post-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: var(--gold);
      color: var(--navy);
      font-weight: 700; font-size: 0.8rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid rgba(201,168,76,0.4);
      flex-shrink: 0;
    }

    .create-post-input-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      border-radius: 999px;
      border: 1.5px solid var(--border);
      background: var(--cream);
      transition: border-color 0.15s, background 0.15s;
      overflow: hidden;
      padding-right: 0.25rem;
    }
    .create-post-input-wrap:focus-within {
      border-color: var(--navy-light);
      background: #fff;
    }

    .create-post-input {
      flex: 1;
      padding: 0.6rem 1rem;
      border: none;
      background: transparent;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--text-dark);
      outline: none;
      cursor: pointer;
    }
    .create-post-input:focus { cursor: text; }
    .create-post-input::placeholder { color: #b0b8c4; }

    .create-post-attach {
      width: 32px; height: 32px;
      border-radius: 50%;
      border: none;
      background: transparent;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      color: var(--text-muted);
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.15s, color 0.15s;
    }
    .create-post-attach:hover {
      background: var(--cream-dark);
      color: var(--navy);
    }

    /* ── Right Sidebar ── */
    .right-sidebar {
      position: fixed; top: var(--topbar-h); right: 0; bottom: 0;
      width: 260px;
      background: #fff; border-left: 1px solid var(--border);
      padding: 1.5rem 1.25rem; overflow-y: auto; z-index: 90;
    }

    .right-sidebar-section { margin-bottom: 2rem; }

    .right-sidebar-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.75rem;
    }

    .right-sidebar-item {
      display: block;
      padding: 0.45rem 0;
      font-size: 0.85rem;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: color 0.15s;
    }
    .right-sidebar-item:last-child { border-bottom: none; }
    .right-sidebar-item:hover { color: var(--navy); }

    /* ── Post Card (from post.html) ── */
    .post-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      position: relative;
      margin-bottom: 1.25rem;
      width: 100%;
    }

    .post-actions {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      display: flex;
      gap: 0.5rem;
    }

    .post-action-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--cream);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      color: var(--text-muted);
      transition: background 0.15s, color 0.15s;
    }
    .post-action-btn:hover {
      background: var(--cream-dark);
      color: var(--navy);
    }

    .post-author {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-right: 8rem;
    }

    .post-avatar {
      width: 56px; height: 56px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--border);
      flex-shrink: 0;
      background: var(--cream-dark);
    }

    .post-avatar-initials {
      width: 56px; height: 56px;
      border-radius: 50%;
      flex-shrink: 0;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--border);
      letter-spacing: 0.03em;
    }

    .post-author-info { display: flex; flex-direction: column; gap: 0.15rem; }

    .post-author-name { font-weight: 600; font-size: 1rem; color: var(--text-dark); }
    .post-author-name a { color: var(--text-dark); text-decoration: none; }
    .post-author-name a:hover { text-decoration: underline; text-underline-offset: 2px; }

    .post-meta { font-size: 0.8rem; color: var(--text-muted); }
    .post-meta a { color: var(--text-muted); text-decoration: none; }
    .post-meta a:hover { color: var(--navy); text-decoration: underline; text-underline-offset: 2px; }

    .post-community { font-size: 0.8rem; color: var(--navy); font-weight: 500; }
    .post-community a { color: var(--navy); text-decoration: none; }
    .post-community a:hover { text-decoration: underline; text-underline-offset: 2px; }

    .post-body {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.6;
    }
  </style>
</head>
<body>

