<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect - Feed</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>
  <style>
    .main {
      margin-right: 260px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .feed-column {
      width: 100%;
      max-width: 620px;
    }

    .page-header { margin-bottom: 1.75rem; }

    .create-post {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 1.25rem;
    }

    .create-post-top {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .create-post-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: var(--gold);
      color: var(--navy);
      font-weight: 700; font-size: 0.8rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid rgba(201,168,76,0.4);
      flex-shrink: 0;
    }

    .create-post-input-wrap {
      flex: 1;
      display: flex;
      align-items: center;
      border-radius: 999px;
      border: 1.5px solid var(--border);
      background: var(--cream);
      overflow: hidden;
      padding-right: 0.25rem;
    }

    .create-post-input {
      flex: 1;
      padding: 0.6rem 1rem;
      border: none;
      background: transparent;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--text-dark);
      outline: none;
    }

    .create-post-attach {
      width: 32px; height: 32px;
      border-radius: 50%;
      border: none;
      background: transparent;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      color: var(--text-muted);
      cursor: pointer;
      flex-shrink: 0;
    }

    .right-sidebar {
      position: fixed; top: var(--topbar-h); right: 0; bottom: 0;
      width: 260px;
      background: #fff; border-left: 1px solid var(--border);
      padding: 1.5rem 1.25rem; overflow-y: auto; z-index: 90;
    }

    .right-sidebar-section { margin-bottom: 2rem; }

    .right-sidebar-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.75rem;
    }

    .right-sidebar-item {
      display: block;
      padding: 0.45rem 0;
      font-size: 0.85rem;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: color 0.15s;
    }

    .right-sidebar-item:last-child { border-bottom: none; }
    .right-sidebar-item:hover { color: var(--navy); }

    .post-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.5rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      position: relative;
      margin-bottom: 1.25rem;
      width: 100%;
    }

    .post-actions {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      display: flex;
      gap: 0.5rem;
    }

    .post-action-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      background: var(--cream);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 1rem;
      color: var(--text-muted);
    }

    .post-author {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-right: 8rem;
    }

    .post-avatar-initials {
      width: 56px; height: 56px;
      border-radius: 50%;
      flex-shrink: 0;
      background: var(--navy);
      color: var(--gold);
      font-weight: 700;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--border);
      letter-spacing: 0.03em;
    }

    .post-author-info { display: flex; flex-direction: column; gap: 0.15rem; }

    .post-author-name { font-weight: 600; font-size: 1rem; color: var(--text-dark); }
    .post-author-name a { color: var(--text-dark); text-decoration: none; }

    .post-meta { font-size: 0.8rem; color: var(--text-muted); }

    .post-community { font-size: 0.8rem; color: var(--navy); font-weight: 500; }
    .post-community a { color: var(--navy); text-decoration: none; }

    .post-body {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      font-size: 0.93rem;
      color: var(--text-dark);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    .empty-state {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
    }
  </style>
</head>
<body>

  <%- include('header', { initials: user && user.initials ? user.initials : 'UC' }) %>

  <div class="layout">

    <%- include('sidebar', { activePage: 'feed' }) %>

    <main class="main">
      <div class="feed-column">
      <% const feedPosts = Array.isArray(posts) ? posts : []; %>
      <% const affiliatedCourses = Array.isArray(courses) ? courses : []; %>
      <% const affiliatedCommunities = Array.isArray(communities) ? communities : []; %>

      <div class="page-header">
        <h1 class="page-title">Feed</h1>
        <p class="page-subtitle">Recent posts from your courses and communities.</p>
      </div>

      <div class="create-post">
        <div class="create-post-top">
          <div class="create-post-avatar"><%= user && user.initials ? user.initials : 'UC' %></div>
          <div class="create-post-input-wrap">
            <input class="create-post-input" type="text" placeholder="What's on your mind?"/>
            <button class="create-post-attach" title="Attach media">📎</button>
          </div>
        </div>
      </div>

      <% if (feedPosts.length === 0) { %>
        <p class="empty-state">No posts found.</p>
      <% } else { %>
        <% feedPosts.forEach((post) => { %>
          <div class="post-card">
            <div class="post-actions">
              <button class="post-action-btn" title="Like">👍</button>
              <button class="post-action-btn" title="Comment">💬</button>
              <button class="post-action-btn" title="Bookmark">🔖</button>
            </div>
            <div class="post-author">
              <div class="post-avatar-initials"><%= post.authorInitials %></div>
              <div class="post-author-info">
                <span class="post-author-name"><a href="/profile"><%= post.authorName %></a></span>
                <span class="post-meta"><a href="/posts/post"><%= post.createdAtLabel %></a></span>
                <span class="post-community"><a href="<%= post.scopeHref %>"><%= post.scopeLabel %></a></span>
              </div>
            </div>
            <div class="post-body"><%= post.content %></div>
          </div>
        <% }) %>
      <% } %>

      </div>
    </main>

    <aside class="right-sidebar">
      <div class="right-sidebar-section">
        <h2 class="right-sidebar-title">Courses</h2>
        <% if (affiliatedCourses.length === 0) { %>
          <span class="right-sidebar-item">None yet</span>
        <% } else { %>
          <% affiliatedCourses.forEach((course) => { %>
            <a href="/courses" class="right-sidebar-item"><%= course.name %></a>
          <% }) %>
        <% } %>
      </div>

      <div class="right-sidebar-section">
        <h2 class="right-sidebar-title">Communities</h2>
        <% if (affiliatedCommunities.length === 0) { %>
          <span class="right-sidebar-item">None yet</span>
        <% } else { %>
          <% affiliatedCommunities.forEach((community) => { %>
            <a href="/communities" class="right-sidebar-item"><%= community.name %></a>
          <% }) %>
        <% } %>
      </div>
    </aside>

  </div>

  <%- include('footer', { footerLayout: 'sidebarBoth' }) %>

</body>
</html>
