<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>UniConnect - Feed</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/stylesheets/style.css"/>
  <link rel="stylesheet" href="/stylesheets/tailwind.css"/>
  <style>
    .main {
      margin-right: 260px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .feed-column {
      width: 100%;
      max-width: 620px;
    }

    .page-header { margin-bottom: 1.75rem; }

    .create-post {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      box-shadow: 0 1px 4px rgba(13,27,42,0.07);
      margin-bottom: 1.25rem;
    }

    .create-post-top {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .create-post-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      background: var(--gold);
      color: var(--navy);
      font-weight: 700; font-size: 0.8rem;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid rgba(201,168,76,0.4);
      flex-shrink: 0;
    }

    .create-post-input-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      border-radius: 12px;
      border: 1.5px solid var(--border);
      background: var(--cream);
      padding: 0.65rem;
    }

    .create-post-input {
      flex: 1;
      min-height: 72px;
      padding: 0.55rem 0.7rem;
      border: none;
      border-radius: 8px;
      background: transparent;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--text-dark);
      outline: none;
      resize: vertical;
    }

    .create-post-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .create-post-submit {
      border: none;
      background: var(--navy);
      color: var(--gold);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.5rem 0.9rem;
      border-radius: 8px;
      cursor: pointer;
      white-space: nowrap;
    }

    .create-post-submit:hover { background: var(--navy-mid); }

    .file-attach-label {
      font-size: 0.82rem;
      color: var(--text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.6rem;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: #fff;
      transition: border-color 0.15s;
    }

    .file-attach-label:hover { border-color: var(--navy); color: var(--navy); }

    .file-name-display {
      font-size: 0.78rem;
      color: var(--navy);
      max-width: 120px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .form-banner {
      border-radius: 10px;
      padding: 0.65rem 0.85rem;
      font-size: 0.84rem;
      margin-bottom: 0.9rem;
    }

    .form-banner.error {
      background: rgba(192,57,43,0.08);
      border: 1px solid rgba(192,57,43,0.25);
      color: #9b2d22;
    }

    .form-banner.success {
      background: rgba(30,126,92,0.08);
      border: 1px solid rgba(30,126,92,0.25);
      color: #1a6c4e;
    }

    .right-sidebar {
      position: fixed; top: var(--topbar-h); right: 0; bottom: 0;
      width: 260px;
      background: #fff; border-left: 1px solid var(--border);
      padding: 1.5rem 1.25rem; overflow-y: auto; z-index: 90;
    }

    .right-sidebar-section { margin-bottom: 2rem; }

    .right-sidebar-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text-dark);
      margin-bottom: 0.75rem;
    }

    .right-sidebar-item {
      display: block;
      padding: 0.45rem 0;
      font-size: 0.85rem;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: color 0.15s;
    }

    .right-sidebar-item:last-child { border-bottom: none; }
    .right-sidebar-item:hover { color: var(--navy); }

    .empty-state {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1rem 1.25rem;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
    }

    .feed-loading {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      padding: 1rem;
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .feed-loader {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      line-height: 1;
    }

    .feed-loader-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(16, 44, 87, 0.3);
      animation: feedDotPulse 0.9s ease-in-out infinite;
    }

    .feed-loader-dot:nth-child(2) {
      animation-delay: 0.12s;
    }

    .feed-loader-dot:nth-child(3) {
      animation-delay: 0.24s;
    }

    @keyframes feedDotPulse {
      0%, 100% { transform: scale(0.92); background: rgba(16, 44, 87, 0.3); }
      50% { transform: scale(1.16); background: rgba(16, 44, 87, 0.9); }
    }

    .feed-skeletons {
      display: grid;
      gap: 0.9rem;
      margin-bottom: 0.7rem;
    }

    .feed-loading[hidden],
    .feed-skeletons[hidden],
    .feed-end[hidden],
    .empty-state[hidden] {
      display: none !important;
    }

    .feed-skeleton-card {
      height: 138px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: linear-gradient(
        100deg,
        rgba(236, 241, 248, 0.65) 35%,
        rgba(255, 255, 255, 0.95) 50%,
        rgba(236, 241, 248, 0.65) 65%
      );
      background-size: 220% 100%;
      animation: feedShimmer 1.1s linear infinite;
    }

    @keyframes feedShimmer {
      to { background-position-x: -220%; }
    }

    .feed-end {
      text-align: center;
      color: var(--text-muted);
      font-size: 0.84rem;
      padding: 0.8rem 0 1.35rem;
    }

    #feed-sentinel {
      height: 1px;
    }

    .post-card.feed-enter {
      animation: feedEnter 0.32s ease-out;
    }

    @keyframes feedEnter {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <%- include('header', { initials: user && user.initials ? user.initials : 'UC' }) %>

  <div class="layout">

    <%- include('sidebar', { activePage: 'feed' }) %>

    <main class="main">
      <div class="feed-column">
      <% const feedPosts = Array.isArray(posts) ? posts : []; %>
      <% const affiliatedCourses = Array.isArray(courses) ? courses : []; %>
      <% const affiliatedCommunities = Array.isArray(communities) ? communities : []; %>
      <% const createPostError = typeof formError === 'string' ? formError : null; %>

      <div class="page-header">
        <h1 class="page-title">Feed</h1>
        <p class="page-subtitle">Recent posts from across UniConnect.</p>
      </div>

      <div class="create-post">
        <% if (createPostError) { %>
          <div class="form-banner error"><%= createPostError %></div>
        <% } %>
        <div class="create-post-top">
          <div class="create-post-avatar"><%= user && user.initials ? user.initials : 'UC' %></div>
          <form class="create-post-input-wrap" method="post" action="/feed/posts" enctype="multipart/form-data">
            <textarea
              class="create-post-input"
              name="content"
              maxlength="4000"
              required
              placeholder="What's on your mind?"
            ></textarea>
            <div class="create-post-row">
              <label class="file-attach-label">
                📎 Attach image
                <input
                  type="file"
                  name="image"
                  accept="image/jpeg,image/png,image/gif,image/webp"
                  style="display:none;"
                  onchange="document.getElementById('file-name-display').textContent = this.files[0]?.name || ''"
                />
              </label>
              <span id="file-name-display" class="file-name-display"></span>
              <button class="create-post-submit" type="submit">Post</button>
            </div>
          </form>
        </div>
      </div>

      <div
        id="feed-posts"
        data-viewer-id="<%= user && user.id ? user.id : '' %>"
        data-viewer-role="<%= user && user.role ? user.role : '' %>"
      >
        <% if (feedPosts.length > 0) { %>
          <% feedPosts.forEach((post) => { %>
            <%- include('partials/post-card', { post }) %>
          <% }) %>
        <% } %>
      </div>

      <p id="feed-empty" class="empty-state" <%= feedPosts.length === 0 ? '' : 'hidden' %>>No posts found.</p>

      <div id="feed-loading" class="feed-loading" hidden>
        <div class="feed-loader" aria-hidden="true">
          <div class="feed-loader-dot"></div>
          <div class="feed-loader-dot"></div>
          <div class="feed-loader-dot"></div>
        </div>
        <span class="feed-loading-label">Loading more posts</span>
      </div>
      <div id="feed-skeletons" class="feed-skeletons" hidden>
        <div class="feed-skeleton-card"></div>
      </div>
      <p id="feed-end" class="feed-end" hidden>You're all caught up.</p>
      <div id="feed-sentinel" aria-hidden="true"></div>

      </div>
    </main>

    <aside class="right-sidebar">
      <div class="right-sidebar-section">
        <h2 class="right-sidebar-title">Courses</h2>
        <% if (affiliatedCourses.length === 0) { %>
          <span class="right-sidebar-item">None yet</span>
        <% } else { %>
          <% affiliatedCourses.forEach((course) => { %>
            <a href="/courses/<%= course.id %>" class="right-sidebar-item"><%= course.name %></a>
          <% }) %>
        <% } %>
      </div>

      <div class="right-sidebar-section">
        <h2 class="right-sidebar-title">Communities</h2>
        <% if (affiliatedCommunities.length === 0) { %>
          <span class="right-sidebar-item">None yet</span>
        <% } else { %>
          <% affiliatedCommunities.forEach((community) => { %>
            <a href="/communities" class="right-sidebar-item"><%= community.name %></a>
          <% }) %>
        <% } %>
      </div>
    </aside>

  </div>

  <%- include('footer', { footerLayout: 'sidebarBoth' }) %>

  <script>
    const latestCommentTimers = new WeakMap();
    const feedPostsContainer = document.getElementById('feed-posts');
    const feedEmptyState = document.getElementById('feed-empty');
    const feedLoading = document.getElementById('feed-loading');
    const feedSkeletons = document.getElementById('feed-skeletons');
    const feedEnd = document.getElementById('feed-end');
    const feedSentinel = document.getElementById('feed-sentinel');
    const viewerId = feedPostsContainer ? feedPostsContainer.dataset.viewerId || '' : '';
    const viewerRole = feedPostsContainer
      ? (feedPostsContainer.dataset.viewerRole || '').trim().toLowerCase()
      : '';
    const pageSize = Number.parseInt('<%= pageSize %>', 10) || 10;
    let nextOffset = Number.parseInt('<%= nextOffset %>', 10) || 0;
    let hasMorePosts = <%= hasMorePosts ? 'true' : 'false' %>;
    let isLoadingMorePosts = false;

    if (typeof window.showUiNotice !== 'function') {
      window.showUiNotice = function showUiNotice(message, variant) {
        let stack = document.getElementById('ui-notice-stack');
        if (!stack) {
          stack = document.createElement('div');
          stack.id = 'ui-notice-stack';
          stack.className = 'ui-notice-stack';
          document.body.appendChild(stack);
        }

        const notice = document.createElement('div');
        const typeClass = variant === 'success' ? 'ui-notice-success' : 'ui-notice-error';
        notice.className = `ui-notice ${typeClass}`;
        notice.textContent = message || 'Something went wrong.';
        stack.appendChild(notice);

        window.setTimeout(() => {
          if (notice.parentNode) notice.parentNode.removeChild(notice);
        }, 3200);
      };
    }

    if (typeof window.confirmUi !== 'function') {
      window.confirmUi = function confirmUi(message) {
        let overlay = document.getElementById('ui-confirm-overlay');
        if (!overlay) {
          overlay = document.createElement('div');
          overlay.id = 'ui-confirm-overlay';
          overlay.className = 'ui-confirm-overlay';
          overlay.hidden = true;
          overlay.innerHTML = `
            <div class="ui-confirm-dialog" role="dialog" aria-modal="true" aria-label="Confirm action">
              <div class="ui-confirm-title">Please confirm</div>
              <div class="ui-confirm-message js-ui-confirm-message"></div>
              <div class="ui-confirm-actions">
                <button type="button" class="ui-confirm-btn ui-confirm-btn-cancel js-ui-confirm-cancel">Cancel</button>
                <button type="button" class="ui-confirm-btn ui-confirm-btn-confirm js-ui-confirm-confirm">Confirm</button>
              </div>
            </div>
          `;
          document.body.appendChild(overlay);
        }

        const messageNode = overlay.querySelector('.js-ui-confirm-message');
        const cancelBtn = overlay.querySelector('.js-ui-confirm-cancel');
        const confirmBtn = overlay.querySelector('.js-ui-confirm-confirm');
        if (messageNode) messageNode.textContent = message || 'Are you sure?';

        return new Promise((resolve) => {
          const close = (value) => {
            overlay.hidden = true;
            overlay.onclick = null;
            if (cancelBtn) cancelBtn.onclick = null;
            if (confirmBtn) confirmBtn.onclick = null;
            resolve(value);
          };

          overlay.hidden = false;
          overlay.onclick = (event) => {
            if (event.target === overlay) close(false);
          };
          if (cancelBtn) cancelBtn.onclick = () => close(false);
          if (confirmBtn) confirmBtn.onclick = () => close(true);
        });
      };
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function updateFeedEmptyState() {
      if (!feedPostsContainer || !feedEmptyState) return;
      feedEmptyState.hidden = feedPostsContainer.querySelector('.post-card') !== null;
    }

    function updateFeedEndState() {
      if (!feedPostsContainer || !feedEnd) return;
      const hasAnyPosts = feedPostsContainer.querySelector('.post-card') !== null;
      feedEnd.hidden = !hasAnyPosts || hasMorePosts || isLoadingMorePosts;
    }

    function setFeedLoadingState(loading) {
      if (feedLoading) feedLoading.hidden = !loading;
      if (feedSkeletons) feedSkeletons.hidden = !loading;
      updateFeedEndState();
    }

    function renderPostCard(post) {
      const postId = post && post.id ? String(post.id) : '';
      const comments = Array.isArray(post && post.comments) ? post.comments : [];
      const latestComment = comments.length > 0 ? comments[comments.length - 1] : null;
      const isOwner = Boolean(viewerId && post && post.authorId && String(post.authorId) === viewerId);
      const isAdmin = viewerRole === 'admin';
      const canDelete = isOwner || isAdmin;
      const commentCount = Number.isInteger(post && post.commentCount) ? post.commentCount : comments.length;
      const likeCount = Number.isInteger(post && post.likeCount) ? post.likeCount : 0;
      const liked = Boolean(post && post.liked);
      const imageHtml = post && post.imageUrl
        ? `<div class="post-image">
            <button
              class="post-image-button js-post-image-trigger"
              type="button"
              data-image-url="${escapeHtml(post.imageUrl)}"
              aria-label="View image larger"
            >
              <img class="post-image-media" src="${escapeHtml(post.imageUrl)}" alt="Post image" loading="lazy"/>
            </button>
          </div>`
        : '';
      const latestCommentHtml = latestComment
        ? `<div class="post-comment-preview" data-post-id="${escapeHtml(postId)}">
            <div class="post-comment post-comment-preview-item">
              <div class="post-comment-avatar">${escapeHtml(latestComment.authorInitials || 'UC')}</div>
              <div class="post-comment-body">
                <div class="post-comment-preview-copy">
                  <span class="post-comment-preview-copy-inner">
                    <strong class="post-comment-preview-name">${escapeHtml(latestComment.authorName || 'Unknown User')}</strong>
                    <span class="post-comment-text post-comment-preview-text">${escapeHtml(latestComment.content || '')}</span>
                  </span>
                  <button class="post-comment-show-more js-comment-expand" type="button" data-post-id="${escapeHtml(postId)}">Show more</button>
                </div>
              </div>
            </div>
          </div>`
        : '';
      const commentsHtml = comments.map((comment) => `
        <div class="post-comment" data-comment-id="${escapeHtml(comment.id)}">
          <div class="post-comment-avatar">${escapeHtml(comment.authorInitials || 'UC')}</div>
          <div class="post-comment-body">
            <div class="post-comment-meta">
              <strong>${escapeHtml(comment.authorName || 'Unknown User')}</strong>
              <span>${escapeHtml(comment.createdAtLabel || '')}</span>
            </div>
            <div class="post-comment-text">${escapeHtml(comment.content || '')}</div>
          </div>
        </div>
      `).join('');

      return `
        <div class="post-card feed-enter" data-post-id="${escapeHtml(postId)}">
          <div class="post-actions">
            <button
              class="post-action-btn like-btn js-like-btn ${liked ? 'active' : ''}"
              title="Like"
              data-post-id="${escapeHtml(postId)}"
              data-liked="${liked ? 'true' : 'false'}"
              aria-pressed="${liked ? 'true' : 'false'}"
            >
              👍 <span class="like-count">${likeCount}</span>
            </button>
            <button class="post-action-btn comment-btn js-comment-toggle" title="Comment" type="button" data-post-id="${escapeHtml(postId)}">
              💬 <span class="comment-count ${commentCount ? '' : 'is-hidden'}">${commentCount || 0}</span>
            </button>
            <button class="post-action-btn js-report-btn" title="Report" type="button" data-post-id="${escapeHtml(postId)}">🚩</button>
            ${canDelete ? `<button class="post-action-btn js-delete-btn" title="Delete" type="button" data-post-id="${escapeHtml(postId)}" style="color: var(--error);">🗑️</button>` : ''}
          </div>

          <div class="post-author">
            <div class="post-avatar-initials">${escapeHtml(post.authorInitials || 'UC')}</div>
            <div class="post-author-info">
              <span class="post-author-name"><a href="${escapeHtml(post.authorProfileHref || '/profile')}">${escapeHtml(post.authorName || 'Unknown User')}</a></span>
              <span class="post-meta"><a href="/post/${escapeHtml(postId)}">${escapeHtml(post.createdAtLabel || '')}</a></span>
              <span class="post-community"><a href="${escapeHtml(post.scopeHref || '#')}">${escapeHtml(post.scopeLabel || 'General')}</a></span>
            </div>
          </div>

          <div class="post-body">${escapeHtml(post.content || '')}</div>
          ${imageHtml}
          ${latestCommentHtml}

          <div class="post-comments" data-post-id="${escapeHtml(postId)}" hidden>
            <div class="post-comment-list">${commentsHtml}</div>
            <form class="post-comment-form js-comment-form" method="post" action="/feed/posts/${escapeHtml(postId)}/comments" data-post-id="${escapeHtml(postId)}">
              <textarea class="post-comment-input" name="content" rows="2" maxlength="2000" placeholder="Write a comment..."></textarea>
              <div class="post-comment-form-actions">
                <button class="post-comment-submit" type="submit">Comment</button>
              </div>
            </form>
          </div>

          <div class="report-modal" id="report-modal-${escapeHtml(postId)}" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:999; align-items:center; justify-content:center;">
            <div style="background:#fff; border-radius:14px; padding:1.5rem; max-width:420px; width:90%;">
              <h3 style="margin-bottom:1rem;">Report Post</h3>
              <textarea id="report-reason-${escapeHtml(postId)}" maxlength="250" rows="3" placeholder="Describe the reason for reporting..." style="width:100%; padding:0.6rem; border-radius:8px; border:1px solid var(--border); margin-bottom:1rem;"></textarea>
              <div style="display:flex; gap:0.75rem; justify-content:flex-end;">
                <button onclick="closeReport('${escapeHtml(postId)}')" style="padding:0.5rem 1rem; border-radius:8px; border:1px solid var(--border); background:#fff; cursor:pointer;">Cancel</button>
                <button onclick="submitReport('${escapeHtml(postId)}')" style="padding:0.5rem 1rem; border-radius:8px; border:none; background:var(--navy); color:white; cursor:pointer;">Submit</button>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    async function loadMorePosts() {
      if (!hasMorePosts || isLoadingMorePosts) return;

      isLoadingMorePosts = true;
      setFeedLoadingState(true);

      try {
        const controller = new AbortController();
        const timeoutId = window.setTimeout(() => controller.abort(), 10000);
        let response;
        try {
          response = await fetch(`/feed/posts?offset=${encodeURIComponent(nextOffset)}&limit=${encodeURIComponent(pageSize)}`, {
            headers: { Accept: 'application/json' },
            signal: controller.signal,
          });
        } finally {
          window.clearTimeout(timeoutId);
        }
        const payload = await response.json();
        if (!response.ok || !payload || payload.ok === false) throw new Error('Unable to load posts.');

        const posts = Array.isArray(payload.posts) ? payload.posts : [];
        if (feedPostsContainer && posts.length > 0) {
          feedPostsContainer.insertAdjacentHTML('beforeend', posts.map(renderPostCard).join(''));
        }

        if (typeof payload.nextOffset === 'number') {
          nextOffset = payload.nextOffset;
        } else {
          nextOffset += posts.length;
        }
        hasMorePosts = Boolean(payload.hasMore);
      } catch (_err) {
        hasMorePosts = false;
      } finally {
        isLoadingMorePosts = false;
        setFeedLoadingState(false);
        updateFeedEmptyState();
        updateFeedEndState();
      }
    }

    window.openReport = function openReport(postId) {
      const modal = document.getElementById(`report-modal-${postId}`);
      if (modal) {
        if (modal.parentElement !== document.body) {
          document.body.appendChild(modal);
        }
        modal.style.display = 'flex';
      }
    };

    window.closeReport = function closeReport(postId) {
      const modal = document.getElementById(`report-modal-${postId}`);
      if (modal) modal.style.display = 'none';
    };

    window.submitReport = async function submitReport(postId) {
      const reasonField = document.getElementById(`report-reason-${postId}`);
      const reason = reasonField ? reasonField.value.trim() : '';
      if (!reason) {
        window.showUiNotice('Please enter a reason.', 'error');
        return;
      }

      try {
        const response = await fetch(`/feed/posts/${postId}/report`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reason }),
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || 'Unable to submit report.');
        }
        window.closeReport(postId);
        if (reasonField) reasonField.value = '';
      } catch (_err) {
        window.showUiNotice(_err.message || 'Unable to submit report.', 'error');
      }
    };

    window.deletePostById = async function deletePostById(postId, triggerEl) {
      const confirmed = await window.confirmUi('Delete this post?');
      if (!confirmed) return;

      try {
        const response = await fetch(`/feed/posts/${postId}`, {
          method: 'DELETE',
          headers: { Accept: 'application/json' },
        });
        if (!response.ok) throw new Error('Unable to delete post.');

        const card = triggerEl && typeof triggerEl.closest === 'function'
          ? triggerEl.closest('.post-card')
          : document.querySelector(`.post-card[data-post-id="${String(postId)}"]`);
        if (card) card.remove();
        updateFeedEmptyState();
        updateFeedEndState();
      } catch (_err) {
        window.showUiNotice('Unable to delete post.', 'error');
      }
    };

    function buildCommentHtml(comment) {
      return `
        <div class="post-comment">
          <div class="post-comment-avatar">${comment.authorInitials || 'UC'}</div>
          <div class="post-comment-body">
            <div class="post-comment-meta">
              <strong>${comment.authorName || 'Unknown User'}</strong>
              <span>${comment.createdAtLabel || ''}</span>
            </div>
            <div class="post-comment-text">${(comment.content || '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')}</div>
          </div>
        </div>
      `;
    }

    function updateCommentBadge(postCard, count) {
      const toggleButton = postCard.querySelector('.js-comment-toggle');
      if (!toggleButton) return;

      let countNode = toggleButton.querySelector('.comment-count');
      if (!countNode) {
        countNode = document.createElement('span');
        countNode.className = 'comment-count';
        toggleButton.appendChild(document.createTextNode(' '));
        toggleButton.appendChild(countNode);
      }

      countNode.textContent = String(count || 0);
      countNode.classList.toggle('is-hidden', !(count > 0));
    }

    function clearLatestCommentHighlight(postCard) {
      const highlightedComment = postCard.querySelector('.post-comment.focused');
      if (highlightedComment) highlightedComment.classList.remove('focused');
    }

    function flashLatestComment(postCard) {
      clearLatestCommentHighlight(postCard);
      const latestComment = postCard.querySelector('.post-comment[data-comment-id]:last-child');
      if (!latestComment) return;

      latestComment.classList.add('focused');
      const existingTimer = latestCommentTimers.get(postCard);
      if (existingTimer) window.clearTimeout(existingTimer);

      const timerId = window.setTimeout(() => {
        latestComment.classList.remove('focused');
        latestCommentTimers.delete(postCard);
      }, 1200);

      latestCommentTimers.set(postCard, timerId);
      latestComment.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function openComments(postCard) {
      const commentsPanel = postCard.querySelector('.post-comments');
      const toggleButton = postCard.querySelector('.js-comment-toggle');
      const preview = postCard.querySelector('.post-comment-preview');
      if (!commentsPanel || !toggleButton || !commentsPanel.hidden) return;

      commentsPanel.hidden = false;
      toggleButton.classList.add('active');
      toggleButton.setAttribute('aria-expanded', 'true');
      if (preview) preview.hidden = true;

      const input = commentsPanel.querySelector('.post-comment-input');
      if (input) input.focus();
    }

    function collapseComments(postCard) {
      const commentsPanel = postCard.querySelector('.post-comments');
      const toggleButton = postCard.querySelector('.js-comment-toggle');
      const preview = postCard.querySelector('.post-comment-preview');
      if (!commentsPanel || !toggleButton) return;

      commentsPanel.hidden = true;
      toggleButton.classList.remove('active');
      toggleButton.setAttribute('aria-expanded', 'false');
      clearLatestCommentHighlight(postCard);

      const timerId = latestCommentTimers.get(postCard);
      if (timerId) {
        window.clearTimeout(timerId);
        latestCommentTimers.delete(postCard);
      }

      if (preview) preview.hidden = false;
    }

    document.addEventListener('click', async (event) => {
      const likeButton = event.target.closest('.js-like-btn');
      if (!likeButton) return;

      event.preventDefault();
      const postId = likeButton.dataset.postId;
      if (!postId || likeButton.dataset.pending === 'true') return;

      const countNode = likeButton.querySelector('.like-count');
      const previousLiked = likeButton.dataset.liked === 'true';
      const previousCount = countNode ? Number.parseInt(countNode.textContent, 10) || 0 : 0;
      const optimisticLiked = !previousLiked;
      const optimisticCount = Math.max(0, previousCount + (optimisticLiked ? 1 : -1));

      likeButton.dataset.pending = 'true';
      likeButton.classList.add('pending');
      likeButton.dataset.liked = optimisticLiked ? 'true' : 'false';
      likeButton.setAttribute('aria-pressed', optimisticLiked ? 'true' : 'false');
      likeButton.classList.toggle('active', optimisticLiked);
      if (countNode) countNode.textContent = String(optimisticCount);

      try {
        const response = await fetch(`/feed/posts/${postId}/like`, {
          method: 'POST',
          headers: { Accept: 'application/json' },
        });

        const payload = await response.json();
        if (!response.ok) throw new Error(payload.error || 'Unable to update like.');

        likeButton.dataset.liked = payload.liked ? 'true' : 'false';
        likeButton.setAttribute('aria-pressed', payload.liked ? 'true' : 'false');
        likeButton.classList.toggle('active', Boolean(payload.liked));
        if (countNode) countNode.textContent = String(payload.likeCount || 0);
      } catch (_err) {
        likeButton.dataset.liked = previousLiked ? 'true' : 'false';
        likeButton.setAttribute('aria-pressed', previousLiked ? 'true' : 'false');
        likeButton.classList.toggle('active', previousLiked);
        if (countNode) countNode.textContent = String(previousCount);
      } finally {
        likeButton.dataset.pending = 'false';
        likeButton.classList.remove('pending');
      }
    });

    document.addEventListener('click', (event) => {
      const commentTrigger = event.target.closest('.js-comment-toggle, .js-comment-expand');
      if (!commentTrigger) return;

      const postCard = commentTrigger.closest('.post-card');
      if (!postCard) return;

      const isToggleButton = commentTrigger.classList.contains('js-comment-toggle');
      const isExpandButton = commentTrigger.classList.contains('js-comment-expand');
      const commentsPanel = postCard.querySelector('.post-comments');
      if (!commentsPanel) return;

      if (isToggleButton) {
        if (commentsPanel.hidden) {
          openComments(postCard);
        } else {
          collapseComments(postCard);
        }
        return;
      }

      if (isExpandButton) {
        if (commentsPanel.hidden) openComments(postCard);
        flashLatestComment(postCard);
      }
    });

    document.addEventListener('submit', async (event) => {
      const commentForm = event.target.closest('.js-comment-form');
      if (!commentForm) return;

      event.preventDefault();

      const postId = commentForm.dataset.postId;
      const input = commentForm.querySelector('.post-comment-input');
      const submitButton = commentForm.querySelector('.post-comment-submit');
      const commentList = commentForm.parentElement.querySelector('.post-comment-list');
      const postCard = commentForm.closest('.post-card');
      const commentsPanel = postCard ? postCard.querySelector('.post-comments') : null;
      const content = input ? input.value.trim() : '';

      if (!postId || !input || !submitButton || !commentList) return;
      if (!content) { input.focus(); return; }

      submitButton.disabled = true;
      submitButton.textContent = 'Posting...';

      try {
        const response = await fetch(`/feed/posts/${postId}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ content }),
        });

        const payload = await response.json();
        if (!response.ok) throw new Error(payload.error || 'Unable to save comment.');

        const comments = Array.isArray(payload.comments) ? payload.comments : [];
        commentList.innerHTML = comments.map(buildCommentHtml).join('');

        if (commentsPanel) commentsPanel.hidden = false;

        const preview = postCard ? postCard.querySelector('.post-comment-preview') : null;
        if (preview) preview.hidden = true;

        if (postCard) {
          const toggleButton = postCard.querySelector('.js-comment-toggle');
          if (toggleButton) {
            toggleButton.classList.add('active');
            toggleButton.setAttribute('aria-expanded', 'true');
          }
        }

        if (postCard && typeof payload.commentCount === 'number') {
          updateCommentBadge(postCard, payload.commentCount);
        }

        if (postCard) {
          const panel = postCard.querySelector('.post-comments');
          if (panel && panel.hidden) openComments(postCard);
        }

        input.value = '';
      } catch (_err) {
        // silent
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Comment';
      }
    });

    if (feedSentinel && 'IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            loadMorePosts();
          }
        });
      }, { rootMargin: '240px 0px' });

      observer.observe(feedSentinel);
    }

    updateFeedEmptyState();
    updateFeedEndState();
  </script>

</body>
</html>
